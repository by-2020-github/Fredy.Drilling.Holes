<UserControl x:Class="Fredy.Drilling.Holes.UserControls.RecipeUserControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Fredy.Drilling.Holes.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Margin="8" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Background="{StaticResource Brush.Background.Subtle}" CornerRadius="6" Padding="6">
        <TabControl>
            <TabItem Header="Map">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Recipe Map" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Brush.Foreground.Secondary}"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding RecipeViewModel.CompletedCount, ElementName=Root, StringFormat=已走: {0}, TargetNullValue=已走: 0}"
                                   Foreground="{StaticResource Brush.Status.Green}"
                                   FontWeight="SemiBold"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="360" Height="360">
                                <Ellipse Width="320"
                                         Height="320"
                                         Stroke="{StaticResource Brush.Border.Strong}"
                                         StrokeThickness="2"
                                         Fill="{StaticResource Brush.Background}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                                <Line X1="180" Y1="20" X2="180" Y2="340" Stroke="{StaticResource Brush.Border}" StrokeThickness="1" StrokeDashArray="4,4"/>
                                <Line X1="20" Y1="180" X2="340" Y2="180" Stroke="{StaticResource Brush.Border}" StrokeThickness="1" StrokeDashArray="4,4"/>
                                <ItemsControl ItemsSource="{Binding DisplayPoints, ElementName=Root}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="360" Height="360"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Fill="{Binding Fill}"
                                                     Stroke="{StaticResource Brush.Background}"
                                                     StrokeThickness="1.2"
                                                     ToolTip="{Binding ToolTip}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{StaticResource Brush.Status.Red}"
                                         Stroke="{StaticResource Brush.Background}"
                                         StrokeThickness="1"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>

                        <TextBlock Text="未加载 Recipe"
                                   FontSize="16"
                                   Foreground="{StaticResource Brush.Foreground.Subtle}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecipeViewModel, ElementName=Root}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="概览">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="配方名称" Foreground="{StaticResource Brush.Foreground.Muted}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Column="1" Text="{Binding RecipeViewModel.RecipeName, ElementName=Root, TargetNullValue=-}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="1" Text="类型" Foreground="{StaticResource Brush.Foreground.Muted}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RecipeViewModel.TypeName, ElementName=Root, TargetNullValue=-}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="2" Text="圆半径" Foreground="{StaticResource Brush.Foreground.Muted}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RecipeViewModel.Radius, ElementName=Root, StringFormat={}{0:N3}, TargetNullValue=-}" FontWeight="SemiBold" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="3" Text="总圈数" Foreground="{StaticResource Brush.Foreground.Muted}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RecipeViewModel.Rings, ElementName=Root, TargetNullValue=-}" FontWeight="SemiBold" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="4" Text="总孔数" Foreground="{StaticResource Brush.Foreground.Muted}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RecipeViewModel.TotalCount, ElementName=Root, TargetNullValue=0}" FontWeight="SemiBold" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="5" Text="已走孔数" Foreground="{StaticResource Brush.Foreground.Muted}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RecipeViewModel.CompletedCount, ElementName=Root, TargetNullValue=0}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Status.Green}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="6" Text="未走孔数" Foreground="{StaticResource Brush.Foreground.Muted}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding RecipeViewModel.RemainingCount, ElementName=Root, TargetNullValue=0}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Foreground.Secondary}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="7" Text="原点" Foreground="{StaticResource Brush.Foreground.Muted}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="圆心 (0, 0)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Border>
</UserControl>

