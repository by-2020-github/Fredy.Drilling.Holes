<UserControl x:Class="Fredy.Drilling.Holes.UserControls.RecipeUserControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Fredy.Drilling.Holes.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#D6D6D6" BorderThickness="1" Background="#FAFAFA" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="Recipe Map" FontSize="16" FontWeight="SemiBold" Foreground="#404040"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding RecipeViewModel.CompletedCount, ElementName=Root, StringFormat=已走: {0}, TargetNullValue=已走: 0}"
                               Foreground="#2E7D32"
                               FontWeight="SemiBold"/>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Viewbox Stretch="Uniform">
                        <Grid Width="360" Height="360">
                            <Ellipse Width="320"
                                     Height="320"
                                     Stroke="#B7B7B7"
                                     StrokeThickness="2"
                                     Fill="White"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                            <Line X1="180" Y1="20" X2="180" Y2="340" Stroke="#E6E6E6" StrokeThickness="1" StrokeDashArray="4,4"/>
                            <Line X1="20" Y1="180" X2="340" Y2="180" Stroke="#E6E6E6" StrokeThickness="1" StrokeDashArray="4,4"/>
                            <ItemsControl ItemsSource="{Binding DisplayPoints, ElementName=Root}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="360" Height="360"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Fill="{Binding Fill}"
                                                 Stroke="White"
                                                 StrokeThickness="1.2"
                                                 ToolTip="{Binding ToolTip}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="#E53935"
                                     Stroke="White"
                                     StrokeThickness="1"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Viewbox>

                    <TextBlock Text="未加载 Recipe"
                               FontSize="18"
                               Foreground="#909090"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecipeViewModel, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,0" BorderBrush="#D6D6D6" BorderThickness="1" Background="White" CornerRadius="6" Padding="12">
            <WrapPanel ItemWidth="150" ItemHeight="56">
                <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="配方名称" Foreground="#7A7A7A"/>
                    <TextBlock Text="{Binding RecipeViewModel.RecipeName, ElementName=Root, TargetNullValue=-}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="类型" Foreground="#7A7A7A"/>
                    <TextBlock Text="{Binding RecipeViewModel.TypeName, ElementName=Root, TargetNullValue=-}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="圆半径" Foreground="#7A7A7A"/>
                    <TextBlock Text="{Binding RecipeViewModel.Radius, ElementName=Root, StringFormat={}{0:N3}, TargetNullValue=-}" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="总圈数" Foreground="#7A7A7A"/>
                    <TextBlock Text="{Binding RecipeViewModel.Rings, ElementName=Root, TargetNullValue=-}" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="总孔数" Foreground="#7A7A7A"/>
                    <TextBlock Text="{Binding RecipeViewModel.TotalCount, ElementName=Root, TargetNullValue=0}" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="已走孔数" Foreground="#7A7A7A"/>
                    <TextBlock Text="{Binding RecipeViewModel.CompletedCount, ElementName=Root, TargetNullValue=0}" FontWeight="SemiBold" Foreground="#2E7D32"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="未走孔数" Foreground="#7A7A7A"/>
                    <TextBlock Text="{Binding RecipeViewModel.RemainingCount, ElementName=Root, TargetNullValue=0}" FontWeight="SemiBold" Foreground="#757575"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="原点" Foreground="#7A7A7A"/>
                    <TextBlock Text="圆心 (0, 0)" FontWeight="SemiBold"/>
                </StackPanel>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
