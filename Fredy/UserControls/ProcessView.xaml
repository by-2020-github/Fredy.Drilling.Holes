<UserControl x:Class="Fredy.Drilling.Holes.Views.ProcessView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Fredy.Drilling.Holes.Converters"
             xmlns:models="clr-namespace:Common.Models;assembly=Common"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1100">
    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource Brush.Background.Subtle}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <GroupBox Header="工件参数" Margin="0,0,0,15" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="工件类型" FontSize="18" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBox Text="{Binding RecipeViewModel.ProcessParameters.WorkpieceType, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                             Width="550" Height="35" FontSize="16" VerticalContentAlignment="Center"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="头道参数" Margin="0,0,0,15" Padding="15">
                <UniformGrid Columns="2">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="头道冲孔深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                        <hc:NumericUpDown Value="{Binding RecipeViewModel.FirstPunchTotalDepth, ElementName=Root, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Style="{StaticResource NumericDoubleUpDownStyle}" Width="100" Height="30"/>
                        <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="断针报警深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                        <hc:NumericUpDown Value="{Binding RecipeViewModel.ProcessParameters.FirstAlarmDepth, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}" Style="{StaticResource NumericDoubleUpDownStyle}" Width="100" Height="30"/>
                        <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="头道抬起高度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                        <hc:NumericUpDown Value="{Binding RecipeViewModel.ProcessParameters.FirstLiftHeight, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}" Style="{StaticResource NumericDoubleUpDownStyle}" Width="100" Height="30"/>
                        <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                    </StackPanel>
                </UniformGrid>
            </GroupBox>

            <GroupBox Header="二道参数" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="头道冲孔深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                            <hc:NumericUpDown Value="{Binding RecipeViewModel.ProcessParameters.SecondPunchDepth, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}" Style="{StaticResource NumericDoubleUpDownStyle}" Width="100" Height="30"/>
                            <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="断针报警深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                            <hc:NumericUpDown Value="{Binding RecipeViewModel.ProcessParameters.SecondAlarmDepth, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}" Style="{StaticResource NumericDoubleUpDownStyle}" Width="100" Height="30"/>
                            <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="头道抬起高度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                            <hc:NumericUpDown Value="{Binding RecipeViewModel.ProcessParameters.SecondLiftHeight, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}" Style="{StaticResource NumericDoubleUpDownStyle}" Width="100" Height="30"/>
                            <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="最低安全深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                            <hc:NumericUpDown Value="{Binding RecipeViewModel.ProcessParameters.MinSafeDepth, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}" Style="{StaticResource NumericDoubleUpDownStyle}" Width="100" Height="30"/>
                            <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                        </StackPanel>
                        <CheckBox Content="二道检测" IsChecked="{Binding RecipeViewModel.ProcessParameters.IsSecondDetectionActive, ElementName=Root}"
                                  IsEnabled="{Binding IsEditing, ElementName=Root}"
                                  FontSize="16" Margin="110,15,0,0"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </StackPanel>

        <GroupBox Grid.Column="1" Header="冲孔深度" Margin="15,0,0,0">
            <DockPanel Margin="5">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="新增数量" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                        <hc:NumericUpDown Value="{Binding RecipeViewModel.AddPunchDepthCount, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource NumericIntUpDownStyle}"
                                          Width="70" Height="28" Margin="0,0,16,0"/>
                  
                    </StackPanel>
                     <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                       
                        <TextBlock Text="默认深度" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                        <hc:NumericUpDown Value="{Binding RecipeViewModel.NewPunchDepthValue, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource NumericDoubleUpDownStyle}"
                                          Width="80" Height="28"/>
                        <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                    </StackPanel>

              

                    <StackPanel Orientation="Horizontal">
                        <Button Content="新增" Width="70" Height="30" Margin="0,0,8,0"
                                Command="{Binding RecipeViewModel.AddPunchDepthItemCommand, ElementName=Root}"/>
                        <Button Content="删除" Width="70" Height="30" Margin="0,0,8,0"
                                Command="{Binding RecipeViewModel.RemoveSelectedPunchDepthItemCommand, ElementName=Root}"/>
                        <Button Content="清空" Width="70" Height="30"
                                Command="{Binding RecipeViewModel.ClearPunchDepthItemsCommand, ElementName=Root}"/>
                    </StackPanel>
                </StackPanel>

                <ListBox ItemsSource="{Binding RecipeViewModel.PunchDepthItems, ElementName=Root}"
                         SelectedItem="{Binding RecipeViewModel.SelectedPunchDepthItem, ElementName=Root, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" FontSize="16"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <hc:NumericUpDown Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                      IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                                                      Style="{StaticResource NumericDoubleUpDownStyle}"
                                                      Width="100" Height="28"/>
                                    <TextBlock Text="mm" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </GroupBox>
    </Grid>
</UserControl>

