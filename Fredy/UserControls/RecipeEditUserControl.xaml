<UserControl
    x:Class="Fredy.Drilling.Holes.UserControls.RecipeEditUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Fredy.Drilling.Holes.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
    xmlns:local="clr-namespace:Fredy.Drilling.Holes.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Fredy.Drilling.Holes.Views"
    x:Name="Root"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource Brush.Background.Subtle}">
        <TabControl Margin="8" DataContext="{Binding RecipeViewModel, ElementName=Root}">
            <TabItem Header="基础信息设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Margin="0,0,12,12"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="配方名称" />
                        <TextBox
                            Grid.Column="1"
                            Height="32"
                            Margin="0,0,0,12"
                            IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                            Text="{Binding RecipeName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Grid.Row="1"
                            Margin="0,0,12,12"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="头道基准类型" />
                        <ComboBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Height="32"
                            Margin="0,0,0,12"
                            IsEnabled="{Binding IsEditing, ElementName=Root}"
                            SelectedValue="{Binding FirstPassReference}"
                            SelectedValuePath="Content">
                            <ComboBoxItem Content="Surface" />
                            <ComboBoxItem Content="Bottom" />
                        </ComboBox>

                        <TextBlock
                            Grid.Row="2"
                            Margin="0,0,12,12"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="工件类型" />
                        <TextBox
                            Grid.Row="2"
                            Grid.Column="1"
                            Height="32"
                            Margin="0,0,0,12"
                            IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                            Text="{Binding TypeName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Grid.Row="3"
                            Margin="0,0,12,12"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="半径" />
                        <hc:NumericUpDown
                            Grid.Row="3"
                            Grid.Column="1"
                            Height="32"
                            Margin="0,0,0,12"
                            IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource NumericDoubleUpDownStyle}"
                            Value="{Binding PunchParameters.Radius, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Grid.Row="4"
                            Margin="0,0,12,12"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="环数" />
                        <hc:NumericUpDown
                            Grid.Row="4"
                            Grid.Column="1"
                            Height="32"
                            Margin="0,0,0,12"
                            IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource NumericIntUpDownStyle}"
                            Value="{Binding PunchParameters.Rings, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Grid.Row="5"
                            Margin="0,0,12,12"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="点位" />
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="1"
                            Margin="0,0,0,12"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Brush.Status.Blue}"
                            Text="{Binding TotalCount, StringFormat=共 {0} 个点位}" />

                        <TextBlock
                            Grid.Row="6"
                            Margin="0,0,12,12"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Text="说明" />
                        <Border
                            Grid.Row="6"
                            Grid.Column="1"
                            Padding="12"
                            Background="{StaticResource Brush.Status.Yellow.Subtle}"
                            BorderBrush="{StaticResource Brush.Status.Yellow}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock
                                Foreground="{StaticResource Brush.Foreground.Secondary}"
                                Text="基础信息页用于维护 Recipe 元数据。冲孔点位新增与维护请切换到第二个 Tab，工艺参数请切换到第三个 Tab。"
                                TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="PunchPoints 点位编辑">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button
                                Width="100"
                                Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding AddPunchPointCommand}"
                                Content="新增单点"
                                IsEnabled="{Binding IsEditing, ElementName=Root}" />
                            <Button
                                Width="100"
                                Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding RemoveSelectedPunchPointCommand}"
                                Content="删除选中"
                                IsEnabled="{Binding IsEditing, ElementName=Root}" />
                            <Button
                                Width="100"
                                Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding SortPunchPointsCommand}"
                                Content="重新排序"
                                IsEnabled="{Binding IsEditing, ElementName=Root}" />
                            <Button
                                Width="130"
                                Height="32"
                                Click="OpenHoleGeneratorWindowButton_Click"
                                Content="打开点集生成器"
                                IsEnabled="{Binding IsEditing, ElementName=Root}" />
                        </StackPanel>
                        <TextBlock
                            VerticalAlignment="Center"
                            DockPanel.Dock="Right"
                            Foreground="{StaticResource Brush.Foreground.Muted}"
                            Text="点集生成器将在独立窗口中打开，用于不同方式生成并预览点位。" />
                    </DockPanel>

                    <local:RecipePunchParametersControl
                        Grid.Row="1"
                        IsEditing="{Binding IsEditing, ElementName=Root}"
                        RecipeViewModel="{Binding RecipeViewModel, ElementName=Root}" />
                </Grid>
            </TabItem>

            <TabItem Header="Detection 一道探测">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="{StaticResource Brush.Status.Green}"
                        Text="0 代表本圈不探测，其他数字 N 代表本圈探测次数" />

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,0,0,10"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DetectionItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="30" Margin="45,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Text="{Binding Index, StringFormat=第{0}圈}" />
                                        <hc:NumericUpDown
                                            Grid.Column="1"
                                            Margin="0"
                                            IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding DetectionCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,8,0,12"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Text="探测偏移量阈值：" />
                        <hc:NumericUpDown
                            Width="160"
                            Height="28"
                            Margin="0"
                            IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource NumericIntUpDownStyle}"
                            Value="{Binding DetectionOffsetThreshold, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="110"
                            Height="34"
                            Command="{Binding ResetDetectionCommand}"
                            Content="重置"
                            IsEnabled="{Binding IsEditing, ElementName=Root}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="SecondPassDetection 二道探测">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="{StaticResource Brush.Status.Green}"
                        Text="0 代表本圈不探测，其他数字 N 代表本圈探测次数" />

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,0,0,10"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SecondPassDetectionItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="30" Margin="45,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Text="{Binding Index, StringFormat=第{0}圈}" />
                                        <hc:NumericUpDown
                                            Grid.Column="1"
                                            Margin="0"
                                            IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding DetectionCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,8,0,12"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Text="探测偏移量阈值：" />
                        <hc:NumericUpDown
                            Width="160"
                            Height="28"
                            Margin="0"
                            IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource NumericIntUpDownStyle}"
                            Value="{Binding SecondPassOffsetThreshold, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="110"
                            Height="34"
                            Command="{Binding ResetSecondPassDetectionCommand}"
                            Content="重置"
                            IsEnabled="{Binding IsEditing, ElementName=Root}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="ProcessParameters 参数编辑">
                <views:ProcessView IsEditing="{Binding IsEditing, ElementName=Root}" RecipeViewModel="{Binding RecipeViewModel, ElementName=Root}" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
