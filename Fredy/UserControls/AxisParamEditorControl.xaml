<UserControl x:Class="Fredy.Drilling.Holes.UserControls.AxisParamEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:Background="White"
             xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="320"
             d:DesignWidth="450">
    <GroupBox Header="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
              Padding="10"
              Margin="0,0,0,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="轴号" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <hc:NumericUpDown Grid.Column="1" Minimum="0" Value="{Binding AxisConfig.AxisNo, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericIntUpDownStyle}" Margin="0,0,12,8"/>
            <TextBlock Grid.Column="2" Text="速度(mm/s)" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <hc:NumericUpDown Grid.Column="3" Minimum="0"  Value="{Binding AxisConfig.Velocity, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Text="加速度(mm/s²)" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <hc:NumericUpDown Grid.Row="1" Minimum="0"  Grid.Column="1" Value="{Binding AxisConfig.Acceleration, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="减速度(mm/s²)" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <hc:NumericUpDown Grid.Row="1" Minimum="0"  Grid.Column="3" Value="{Binding AxisConfig.Deceleration, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2" Text="左限位(mm)" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding AxisConfig.LeftLimit, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,12,8"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="右限位(mm)" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <hc:NumericUpDown Grid.Row="2" Grid.Column="3" Value="{Binding AxisConfig.RightLimit, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="3" Text="每mm脉冲数" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <hc:NumericUpDown Grid.Row="3" Grid.Column="1" Minimum="1"  Value="{Binding AxisConfig.PulsesPerMillimeter, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,12,0"/>

            <TextBlock Grid.Row="4" Text="硬件闭环" VerticalAlignment="Center" Margin="0,8,8,0"/>
            <CheckBox Grid.Row="4"
                      Grid.Column="1"
                      Grid.ColumnSpan="3"
                      Content="伺服闭环"
                      IsChecked="{Binding AxisConfig.UseActualPositionFeedback, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                      Margin="0,8,0,0"/>

            <TextBlock Grid.Row="5" Text="到位误差(mm)" VerticalAlignment="Center" Margin="0,8,8,0"/>
            <hc:NumericUpDown Grid.Row="5"
                              Grid.Column="1"
                              Value="{Binding AxisConfig.InPositionTolerance, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}"
                              Margin="0,8,12,0">
                <hc:NumericUpDown.Style>
                    <Style TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericDoubleUpDownStyle}">
                        <Setter Property="IsEnabled" Value="False"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AxisConfig.UseActualPositionFeedback, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                <Setter Property="IsEnabled" Value="True"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </hc:NumericUpDown.Style>
            </hc:NumericUpDown>

            <TextBlock Grid.Row="6" Text="快速寻零(mm/s)" VerticalAlignment="Center" Margin="0,8,8,0"/>
            <hc:NumericUpDown Grid.Row="6"
                              Grid.Column="1"
                              Minimum="0"
                              Value="{Binding AxisConfig.FastHomeSearchSpeed, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource NumericDoubleUpDownStyle}"
                              Margin="0,8,12,0"/>
            <TextBlock Grid.Row="6" Grid.Column="2" Text="慢速寻零(mm/s)" VerticalAlignment="Center" Margin="0,8,8,0"/>
            <hc:NumericUpDown Grid.Row="6"
                              Grid.Column="3"
                              Minimum="0"
                              Value="{Binding AxisConfig.SlowHomeSearchSpeed, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource NumericDoubleUpDownStyle}"
                              Margin="0,8,0,0"/>

            <TextBlock Grid.Row="7" Text="回零超时(ms)" VerticalAlignment="Center" Margin="0,8,8,0"/>
            <hc:NumericUpDown Grid.Row="7"
                              Grid.Column="1"
                              Minimum="0"
                              Value="{Binding AxisConfig.HomeTimeoutMs, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource NumericIntUpDownStyle}"
                              Margin="0,8,12,0"/>
            <TextBlock Grid.Row="7" Grid.Column="2" Text="最大重试次数" VerticalAlignment="Center" Margin="0,8,8,0"/>
            <hc:NumericUpDown Grid.Row="7"
                              Grid.Column="3"
                              Minimum="1"
                              Value="{Binding AxisConfig.HomeMaxRetryCount, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource NumericIntUpDownStyle}"
                              Margin="0,8,0,0"/>

            <TextBlock Grid.Row="8"
                       Grid.ColumnSpan="4"
                       Text="轴级回零参数优先生效；速度或超时设为 0 时沿用默认回零配置。"
                       Foreground="Gray"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"/>
        </Grid>
    </GroupBox>
</UserControl>
