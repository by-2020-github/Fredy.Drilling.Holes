<UserControl x:Class="Fredy.Drilling.Holes.UserControls.NinePointCalibrationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="320"
             d:DesignWidth="520">
    <Border Margin="0,10,0,0" Padding="8" BorderBrush="{StaticResource Brush.Status.Green}" BorderThickness="1" CornerRadius="4" Background="{StaticResource Brush.Status.Green.Subtle}">
        <StackPanel>
            <TextBlock Text="九点标定" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton Content="手动输入" IsChecked="{Binding IsManualMode}" Margin="0,0,16,0"/>
                <RadioButton Content="现场九点标定" IsChecked="{Binding IsFieldMode}"/>
            </StackPanel>

            <Grid Visibility="{Binding ManualPanelVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="X 像素尺寸(μm)" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding ManualPixelSizeX, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,15,0"/>
                <TextBlock Grid.Column="2" Text="Y 像素尺寸(μm)" VerticalAlignment="Center"/>
                <TextBox Grid.Column="3" Text="{Binding ManualPixelSizeY, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0"/>
            </Grid>

            <Button Content="应用手动值"
                    Width="120"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Left"
                    Command="{Binding ApplyManualCommand}"
                    Visibility="{Binding ManualPanelVisibility}"/>

            <StackPanel Visibility="{Binding FieldPanelVisibility}">
                <WrapPanel Margin="0,4,0,8">
                    <TextBlock Text="相邻点物理间距 X(mm)" VerticalAlignment="Center"/>
                    <TextBox Width="70" Margin="6,0,16,0" Text="{Binding StagePitchX, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Y(mm)" VerticalAlignment="Center"/>
                    <TextBox Width="70" Margin="6,0,16,0" Text="{Binding StagePitchY, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="重置九点" Width="80" Command="{Binding ResetPointsCommand}"/>
                </WrapPanel>

                <DataGrid ItemsSource="{Binding Points}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          Height="150">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="点位" Binding="{Binding Index}" IsReadOnly="True" Width="60"/>
                        <DataGridTextColumn Header="像素 X" Binding="{Binding PixelX, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="像素 Y" Binding="{Binding PixelY, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <WrapPanel Margin="0,8,0,0">
                    <Button Content="计算并应用" Width="110" Command="{Binding CalculateAndApplyCommand}" />
                    <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding CalibrationResultText}" Foreground="{StaticResource Brush.Status.Green}"/>
                </WrapPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>





