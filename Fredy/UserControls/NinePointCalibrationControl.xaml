<UserControl x:Class="Fredy.Drilling.Holes.UserControls.NinePointCalibrationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="1024"
             d:DesignWidth="1280">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0,10,0,0" MaxWidth="1220" HorizontalAlignment="Center">
            <Border Padding="16"
                    BorderBrush="{StaticResource Brush.Status.Green}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="{StaticResource Brush.Status.Green.Subtle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="九点标定" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource Brush.Foreground.Secondary}"
                                   Text="可直接录入像素尺寸，或根据 3×3 九点像素坐标自动计算 X/Y 像素尺寸。"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,14,0,14"
                            Padding="12"
                            CornerRadius="4"
                            Background="{StaticResource Brush.Background.Subtle}">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Margin="0,0,18,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="标定模式"/>
                            <RadioButton Content="手动输入" IsChecked="{Binding IsManualMode}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                            <RadioButton Content="现场九点标定" IsChecked="{Binding IsFieldMode}" VerticalAlignment="Center"/>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <GroupBox Header="手动输入" Visibility="{Binding ManualPanelVisibility}">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock VerticalAlignment="Center" Text="X 像素尺寸(μm)"/>
                                <hc:NumericUpDown Grid.Column="1"
                                                  Margin="8,0,18,0"
                                                  Value="{Binding ManualPixelSizeX, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource NumericDoubleUpDownStyle}"/>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Y 像素尺寸(μm)"/>
                                <hc:NumericUpDown Grid.Column="3"
                                                  Margin="8,0,0,0"
                                                  Value="{Binding ManualPixelSizeY, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource NumericDoubleUpDownStyle}"/>

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Margin="0,16,0,0">
                                    <Button Content="应用手动值"
                                            Width="140"
                                            Height="34"
                                            HorizontalAlignment="Left"
                                            Command="{Binding ApplyManualCommand}"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="现场九点标定" Visibility="{Binding FieldPanelVisibility}">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center" Text="相邻点物理间距 X(mm)"/>
                                    <hc:NumericUpDown Grid.Column="1"
                                                      Margin="8,0,18,0"
                                                      Value="{Binding StagePitchX, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource NumericDoubleUpDownStyle}"/>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Y(mm)"/>
                                    <hc:NumericUpDown Grid.Column="3"
                                                      Margin="8,0,18,0"
                                                      Value="{Binding StagePitchY, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource NumericDoubleUpDownStyle}"/>
                                    <Button Grid.Column="4"
                                            Width="96"
                                            Height="32"
                                            HorizontalAlignment="Left"
                                            Content="重置九点"
                                            Command="{Binding ResetPointsCommand}"/>
                                </Grid>

                                <DataGrid Grid.Row="1"
                                          MinHeight="240"
                                          MaxHeight="520"
                                          ItemsSource="{Binding Points}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="点位" Binding="{Binding Index}" IsReadOnly="True" Width="80"/>
                                        <DataGridTextColumn Header="像素 X" Binding="{Binding PixelX, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                        <DataGridTextColumn Header="像素 Y" Binding="{Binding PixelY, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Width="120"
                                            Height="34"
                                            Content="计算并应用"
                                            Command="{Binding CalculateAndApplyCommand}"/>
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.Status.Green}"
                                               Text="{Binding CalibrationResultText}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>





