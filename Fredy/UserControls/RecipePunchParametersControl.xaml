<UserControl x:Class="Fredy.Drilling.Holes.UserControls.RecipePunchParametersControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Fredy.Drilling.Holes.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">
	<UserControl.Resources>
		<converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
		<Style x:Key="MapPointPresenterStyle" TargetType="ContentPresenter">
			<Setter Property="Canvas.Left" Value="{Binding Left}"/>
			<Setter Property="Canvas.Top" Value="{Binding Top}"/>
		</Style>
	</UserControl.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="12"/>
			<RowDefinition Height="260"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0"
                Background="White"
                BorderBrush="#D6D6D6"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<DockPanel Margin="0,0,0,8">
					<TextBlock Text="点位 Map"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#404040"/>
					<TextBlock DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="#666666"
                               Text="滚轮缩放，左键空白区域拖拽，点击点位选择"/>
				</DockPanel>

				<Grid Grid.Row="1"
                      x:Name="PunchPointMapViewport"
                      Background="#F9FBFD"
                      ClipToBounds="True"
                      SizeChanged="PunchPointMapViewport_SizeChanged"
                      MouseLeftButtonDown="PunchPointMapViewport_MouseLeftButtonDown"
                      MouseLeftButtonUp="PunchPointMapViewport_MouseLeftButtonUp"
                      MouseMove="PunchPointMapViewport_MouseMove"
                      MouseWheel="PunchPointMapViewport_MouseWheel"
                      LostMouseCapture="PunchPointMapViewport_LostMouseCapture">
					<Grid.ContextMenu>
						<ContextMenu>
							<MenuItem Header="重置视图" Click="ResetMapViewMenuItem_Click"/>
							<MenuItem Header="适配全部点" Click="FitAllPointsMenuItem_Click"/>
						</ContextMenu>
					</Grid.ContextMenu>
					<Canvas>
						<Grid x:Name="PunchPointMapContent"
							  Width="640"
							  Height="640"
							  HorizontalAlignment="Left"
							  VerticalAlignment="Top"
							  RenderTransformOrigin="0,0">
							<Ellipse Width="560"
									 Height="560"
									 Stroke="#C9D3DD"
									 StrokeThickness="2"
									 Fill="#FFFFFF"
									 HorizontalAlignment="Center"
									 VerticalAlignment="Center"/>
							<Line X1="320" Y1="24" X2="320" Y2="616" Stroke="#DDE5ED" StrokeThickness="1" StrokeDashArray="4,4"/>
							<Line X1="24" Y1="320" X2="616" Y2="320" Stroke="#DDE5ED" StrokeThickness="1" StrokeDashArray="4,4"/>

							<ItemsControl  ItemsSource="{Binding DisplayPoints, ElementName=Root}"
										  ItemContainerStyle="{StaticResource MapPointPresenterStyle}">
								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<Canvas Width="640" Height="640"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Grid Width="{Binding Size}"
											  Height="{Binding Size}"
											  Cursor="Hand"
											  MouseLeftButtonDown="MapPoint_MouseLeftButtonDown"
											  ToolTip="{Binding ToolTip}">
											<Ellipse Fill="{Binding Fill}"
													 Stroke="{Binding Stroke}"
													 StrokeThickness="{Binding StrokeThickness}"/>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<Ellipse Width="10"
									 Height="10"
									 Fill="#EF5350"
									 Stroke="White"
									 StrokeThickness="1.2"
									 HorizontalAlignment="Center"
									 VerticalAlignment="Center"/>
						</Grid>
					</Canvas>
					<TextBlock Text="当前没有 PunchPoints"
                               FontSize="18"
                               Foreground="#9A9A9A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Visibility" Value="Collapsed"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding RecipeViewModel.TotalCount, ElementName=Root}" Value="0">
										<Setter Property="Visibility" Value="Visible"/>
									</DataTrigger>
									<DataTrigger Binding="{Binding RecipeViewModel, ElementName=Root}" Value="{x:Null}">
										<Setter Property="Visibility" Value="Visible"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
				</Grid>
			</Grid>
		</Border>

		<DataGrid x:Name="PunchPointsDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  ItemsSource="{Binding RecipeViewModel.PunchPoints, ElementName=Root}"
                  SelectedItem="{Binding RecipeViewModel.SelectedPunchPoint, ElementName=Root, Mode=TwoWay}"
                  SelectionMode="Single"
                  SelectionChanged="PunchPointsDataGrid_SelectionChanged"
                  IsReadOnly="{Binding IsEditing, ElementName=Root, Converter={StaticResource InverseBoolConverter}}">
			<DataGrid.Columns>
				<DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
				<DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
				<DataGridTextColumn Header="RingNumber" Binding="{Binding RingNumber, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
				<DataGridTextColumn Header="SequenceIndex" Binding="{Binding SequenceIndex, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
				<DataGridCheckBoxColumn Header="完成" Binding="{Binding Complete, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
			</DataGrid.Columns>
		</DataGrid>
	</Grid>
</UserControl>
