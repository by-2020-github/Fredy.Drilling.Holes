<UserControl x:Class="Fredy.Drilling.Holes.UserControls.MotionDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Fredy.Drilling.Holes.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1080"
             d:DataContext="{d:DesignInstance Type=local:MotionDebugViewModel, IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="控制器初始化" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="控制器类型"/>
                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              ItemsSource="{Binding MotionTypes}"
                              SelectedItem="{Binding SelectedMotionType}"
                              MinWidth="160"/>

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="5"
                               Margin="0,12,0,8"
                               FontWeight="SemiBold"
                               Text="ADT8940 初始化参数"
                               Visibility="{Binding IsMotionAdt8940Selected, Converter={StaticResource BoolToVis}}"/>

                    <WrapPanel Grid.Row="2"
                               Grid.ColumnSpan="5"
                               Margin="0,0,0,8"
                               Visibility="{Binding IsMotionAdt8940Selected, Converter={StaticResource BoolToVis}}">
                        <StackPanel Width="120" Margin="0,0,12,8">
                            <TextBlock Text="CardNo"/>
                            <TextBox Text="{Binding CardNo, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Width="120" Margin="0,0,12,8">
                            <TextBlock Text="StartSpeed"/>
                            <TextBox Text="{Binding StartSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Width="120" Margin="0,0,12,8">
                            <TextBlock Text="DriveSpeed"/>
                            <TextBox Text="{Binding DriveSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Width="120" Margin="0,0,12,8">
                            <TextBlock Text="Acceleration"/>
                            <TextBox Text="{Binding Acceleration, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Width="140" Margin="0,0,12,8">
                            <TextBlock Text="HomeSearchSpeed"/>
                            <TextBox Text="{Binding HomeSearchSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Width="150" Margin="0,0,12,8">
                            <TextBlock Text="HomeApproachSpeed"/>
                            <TextBox Text="{Binding HomeApproachSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Grid.Row="3"
                                Grid.ColumnSpan="5"
                                Margin="0,12,0,0"
                                Orientation="Horizontal">
                        <Button Width="120"
                                Height="32"
                                Margin="0,0,8,0"
                                Command="{Binding InitializeCommand}"
                                Content="初始化"/>
                        <Button Width="120"
                                Height="32"
                                Margin="0,0,12,0"
                                Command="{Binding ResetControllerCommand}"
                                Content="释放控制器"/>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="DarkSlateBlue"
                                   Text="{Binding StatusMessage}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="轴调试" Padding="12" IsEnabled="{Binding IsInitialized}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="AxisNo"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AxisNo, UpdateSourceTrigger=PropertyChanged}"/>

                        <CheckBox Grid.Row="0"
                                  Grid.Column="3"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding WaitForCompletion}"
                                  Content="等待完成"/>
                        <CheckBox Grid.Row="0"
                                  Grid.Column="4"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding AutoRefreshPosition}"
                                  Content="后台刷新位置"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Text="当前坐标"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" IsReadOnly="True" Text="{Binding CurrentPosition, StringFormat=F3}"/>
                        <Button Grid.Row="1"
                                Grid.Column="4"
                                Margin="0,12,0,0"
                                Width="120"
                                Height="30"
                                HorizontalAlignment="Left"
                                Command="{Binding RefreshPositionCommand}"
                                Content="读取位置"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Text="绝对位置"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Text="{Binding AbsolutePosition, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="2" Grid.Column="3" Margin="0,12,8,0" VerticalAlignment="Center" Text="相对距离"/>
                        <TextBox Grid.Row="2" Grid.Column="4" Margin="0,12,0,0" Text="{Binding RelativeDistance, UpdateSourceTrigger=PropertyChanged}"/>

                        <UniformGrid Grid.Row="3" Grid.ColumnSpan="6" Margin="0,16,0,0" Columns="4">
                            <Button Margin="4" Height="34" Command="{Binding EnableAxisCommand}" Content="使能"/>
                            <Button Margin="4" Height="34" Command="{Binding DisableAxisCommand}" Content="禁用"/>
                            <Button Margin="4" Height="34" Command="{Binding HomeAxisCommand}" Content="回零"/>
                            <Button Margin="4" Height="34" Command="{Binding MoveAbsoluteCommand}" Content="绝对移动"/>
                            <Button Margin="4" Height="34" Command="{Binding MoveRelativeCommand}" Content="相对移动"/>
                            <Button Margin="4" Height="34" Command="{Binding StopAxisCommand}" Content="减速停止"/>
                            <Button Margin="4" Height="34" Command="{Binding EmergencyStopAxisCommand}" Content="急停"/>
                        </UniformGrid>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Column="2" Header="操作日志" Padding="12">
                    <DockPanel>
                        <Button DockPanel.Dock="Top"
                                Width="100"
                                Height="30"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Right"
                                Command="{Binding ClearLogCommand}"
                                Content="清空日志"/>
                        <ListBox ItemsSource="{Binding Logs}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </GroupBox>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
