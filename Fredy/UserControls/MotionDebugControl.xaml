<UserControl
    x:Class="Fredy.Drilling.Holes.UserControls.MotionDebugControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
    xmlns:local="clr-namespace:Fredy.Drilling.Holes.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Fredy.Drilling.Holes.Models"
    d:Background="{StaticResource Brush.Background}"
    d:DataContext="{d:DesignInstance Type=local:MotionDebugViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="720"
    d:DesignWidth="1080"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <!--
        外层 Grid 仅保留控制区，日志统一显示在主界面日志面板。
    -->
    <ScrollViewer
        CanContentScroll="True"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="1160"
            Margin="12"
            HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox
                Grid.Row="0"
                Padding="12"
                Header="控制器初始化">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Text="控制器类型" />
                    <ComboBox
                        Grid.Row="0"
                        Grid.Column="1"
                        MinWidth="180"
                        ItemsSource="{Binding MotionTypes}"
                        SelectedItem="{Binding SelectedMotionType}" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0,10,0,6"
                        FontWeight="SemiBold"
                        Text="ADT8940 初始化参数"
                        Visibility="{Binding IsMotionAdt8940Selected, Converter={StaticResource BoolToVis}}" />

                    <UniformGrid
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Margin="0,0,0,6"
                        Columns="3"
                        Visibility="{Binding IsMotionAdt8940Selected, Converter={StaticResource BoolToVis}}">
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="CardNo" />
                            <hc:NumericUpDown Style="{StaticResource NumericIntUpDownStyle}" Value="{Binding CardNo, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="起始速度 (mm/s)" />
                            <hc:NumericUpDown Style="{StaticResource NumericDoubleUpDownStyle}" Value="{Binding StartSpeed, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="运行速度 (mm/s)" />
                            <hc:NumericUpDown Style="{StaticResource NumericDoubleUpDownStyle}" Value="{Binding DriveSpeed, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="加速度 (mm/s²)" />
                            <hc:NumericUpDown Style="{StaticResource NumericDoubleUpDownStyle}" Value="{Binding Acceleration, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="搜索速度 (mm/s)" />
                            <hc:NumericUpDown Style="{StaticResource NumericDoubleUpDownStyle}" Value="{Binding HomeSearchSpeed, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="逼近速度 (mm/s)" />
                            <hc:NumericUpDown Style="{StaticResource NumericDoubleUpDownStyle}" Value="{Binding HomeApproachSpeed, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </UniformGrid>

                    <WrapPanel
                        Grid.Row="3"
                        Grid.ColumnSpan="2"
                        Margin="0,10,0,0"
                        ItemHeight="32">
                        <Button
                            Width="110"
                            Height="32"
                            Margin="0,0,8,8"
                            Command="{Binding InitializeCommand}"
                            Content="初始化" />
                        <Button
                            Width="110"
                            Height="32"
                            Margin="0,0,0,8"
                            Command="{Binding ResetControllerCommand}"
                            Content="释放控制器" />
                    </WrapPanel>

                    <Border
                        Grid.Row="4"
                        Grid.ColumnSpan="2"
                        Margin="0,4,0,0"
                        Padding="8,6"
                        Background="{StaticResource Brush.Status.Blue.Subtle}"
                        CornerRadius="4">
                        <TextBlock
                            Foreground="DarkSlateBlue"
                            Text="{Binding StatusMessage}"
                            TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox
                Grid.Row="1"
                Margin="0,8,0,0"
                Padding="12">
                <GroupBox.Header>
                    <DockPanel LastChildFill="False">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="单轴调试" />
                        <Button
                            Height="28"
                            MinWidth="72"
                            Margin="12,0,0,0"
                            Padding="12,0"
                            Command="{Binding AddAxisCommand}"
                            Content="Add" />
                    </DockPanel>
                </GroupBox.Header>

                <ItemsControl ItemsSource="{Binding AxisItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:MotionDebugAxisItem}">
                            <Border
                                Margin="0,0,0,8"
                                Padding="10"
                                Background="{StaticResource Brush.Background.Subtle}"
                                BorderBrush="{StaticResource Brush.Border.Strong}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <DockPanel
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="5"
                                        LastChildFill="False">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{Binding AxisNo, StringFormat=轴号: Axis {0}}" />
                                        <Button
                                            Width="72"
                                            Height="28"
                                            Margin="12,0,0,0"
                                            Command="{Binding DataContext.DeleteAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="删除轴" />
                                    </DockPanel>

                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,10,12,0">
                                        <TextBlock Text="当前坐标 (mm)" />
                                        <TextBox IsReadOnly="True" Text="{Binding CurrentPosition, StringFormat=F3}" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,10,12,0">
                                        <TextBlock Text="绝对位置 (mm)" />
                                        <hc:NumericUpDown Style="{StaticResource NumericDoubleUpDownStyle}" Value="{Binding AbsolutePosition, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Margin="0,10,12,0">
                                        <TextBlock Text="相对距离 (mm)" />
                                        <hc:NumericUpDown Style="{StaticResource NumericDoubleUpDownStyle}" Value="{Binding RelativeDistance, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="3"
                                        Margin="0,10,0,0">
                                        <TextBlock Text="速度 (mm/s)" />
                                        <hc:NumericUpDown Style="{StaticResource NumericDoubleUpDownStyle}" Value="{Binding Speed, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <UniformGrid
                                        Grid.Row="2"
                                        Grid.ColumnSpan="5"
                                        Margin="0,10,0,0"
                                        Columns="7">
                                        <Button
                                            Height="32"
                                            Margin="4"
                                            Command="{Binding DataContext.MoveAbsoluteAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="绝对移动" />
                                        <Button
                                            Height="32"
                                            Margin="4"
                                            Command="{Binding DataContext.MoveRelativeAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="相对移动" />
                                        <Button
                                            Height="32"
                                            Margin="4"
                                            Command="{Binding DataContext.SetAxisSpeedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="设置速度" />
                                        <Button
                                            Height="32"
                                            Margin="4"
                                            Command="{Binding DataContext.EnableAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="使能" />
                                        <Button
                                            Height="32"
                                            Margin="4"
                                            Command="{Binding DataContext.DisableAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="关闭使能" />
                                        <Button
                                            Height="32"
                                            Margin="4"
                                            Background="{StaticResource Brush.Status.Green}"
                                            Command="{Binding DataContext.ResetAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="复位"
                                            Foreground="{StaticResource Brush.Foreground.Inverse}" />
                                        <Button
                                            Height="32"
                                            Margin="4"
                                            Background="{StaticResource Brush.Status.Red}"
                                            Command="{Binding DataContext.EmergencyStopAxisCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="急停"
                                            Foreground="{StaticResource Brush.Foreground.Inverse}" />
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="GPIO_IN">
                    <ItemsControl ItemsSource="{Binding GpioIn}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GpioItem}">
                                <Border
                                    Height="22"
                                    Margin="1"
                                    Background="{Binding IsActive, Converter={StaticResource StatusColorConverter}}"
                                    BorderBrush="{StaticResource Brush.Border.Strong}"
                                    BorderThickness="1">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        Text="{Binding Id}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <GroupBox Grid.Column="2" Header="GPIO_OUT">
                    <ItemsControl ItemsSource="{Binding GpioOut}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GpioItem}">
                                <Button
                                    Width="28"
                                    Height="22"
                                    Margin="2"
                                    Padding="0"
                                    Background="{Binding IsActive, Converter={StaticResource StatusColorConverter}}"
                                    BorderBrush="{StaticResource Brush.Border.Strong}"
                                    BorderThickness="1"
                                    Command="{Binding DataContext.ToggleOutputCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Id}">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Text="{Binding Id}" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
