<UserControl x:Class="Fredy.Drilling.Holes.UserControls.PunchProcessAuditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="820"
             d:DesignWidth="1200">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="270"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderThickness="1" BorderBrush="#D6D6D6" Background="#F8FAFC" CornerRadius="6" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="冲孔流程审计" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ProcessMode}" Margin="0,4,0,0" Foreground="#3B82F6" FontWeight="SemiBold"/>
                    <TextBlock Margin="0,6,0,0">
                        <Run Text="当前状态: "/>
                        <Run Text="{Binding CurrentState}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="流程结果: "/>
                        <Run Text="{Binding CompletionStatus}" FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="整体冲孔进度" FontWeight="SemiBold"/>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Height="20" Margin="0,6,0,0"/>
                    <TextBlock HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Run Text="{Binding CompletedHoles}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalHoles}"/>
                        <Run Text=" ("/>
                        <Run Text="{Binding ProgressPercent, StringFormat=F2}"/>
                        <Run Text="%)"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <GroupBox Grid.Row="1" Header="孔位轨迹平面图 (点阵热力图)" Margin="0,10,0,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <Ellipse Width="12" Height="12" Fill="OrangeRed" Stroke="Yellow" StrokeThickness="1"/>
                        <TextBlock Text=" 当前孔" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <Ellipse Width="12" Height="12" Fill="DeepSkyBlue" Stroke="Black" StrokeThickness="1"/>
                        <TextBlock Text=" 最近邻采样点" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <Ellipse Width="12" Height="12" Fill="ForestGreen"/>
                        <TextBlock Text=" 已完成" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <Ellipse Width="12" Height="12" Fill="DimGray"/>
                        <TextBlock Text=" 未完成" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="滚轮缩放 / 左键拖动" VerticalAlignment="Center" Foreground="#94A3B8"/>
                </StackPanel>

                <Border Grid.Row="1"
                        x:Name="HeatmapViewport"
                        BorderBrush="#D6D6D6"
                        BorderThickness="1"
                        Background="#0B1220"
                        CornerRadius="4"
                        Padding="6"
                        ClipToBounds="True"
                        MouseWheel="HeatmapViewport_MouseWheel"
                        MouseLeftButtonDown="HeatmapViewport_MouseLeftButtonDown"
                        MouseLeftButtonUp="HeatmapViewport_MouseLeftButtonUp"
                        MouseMove="HeatmapViewport_MouseMove"
                        LostMouseCapture="HeatmapViewport_LostMouseCapture">
                    <Grid x:Name="HeatmapContentLayer" RenderTransformOrigin="0,0">
                        <Canvas Width="940" Height="230" IsHitTestVisible="False">
                            <Line X1="470" Y1="0" X2="470" Y2="230" Stroke="#334155" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <Line X1="0" Y1="115" X2="940" Y2="115" Stroke="#334155" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <Ellipse Width="6" Height="6" Fill="#94A3B8" Canvas.Left="467" Canvas.Top="112"/>
                            <TextBlock Text="O(0,0)" Foreground="#94A3B8" FontSize="10" Canvas.Left="474" Canvas.Top="118"/>
                            <TextBlock Text="+X" Foreground="#94A3B8" FontSize="10" Canvas.Left="918" Canvas.Top="118"/>
                            <TextBlock Text="+Y" Foreground="#94A3B8" FontSize="10" Canvas.Left="474" Canvas.Top="2"/>

                            <Line X1="{Binding LinkX1}"
                                  Y1="{Binding LinkY1}"
                                  X2="{Binding LinkX2}"
                                  Y2="{Binding LinkY2}"
                                  Stroke="#FDE047"
                                  StrokeThickness="1.5"
                                  StrokeDashArray="4,2"
                                  Visibility="{Binding LinkVisibility}"/>
                        </Canvas>

                        <ItemsControl ItemsSource="{Binding HeatmapPoints}" IsHitTestVisible="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="940" Height="230"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse Width="{Binding Size}"
                                             Height="{Binding Size}"
                                             Fill="{Binding Fill}"
                                             Stroke="{Binding Stroke}"
                                             StrokeThickness="{Binding StrokeThickness}"
                                             ToolTip="{Binding ToolTip}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>

        <DataGrid Grid.Row="2"
                  Margin="0,10,0,0"
                  ItemsSource="{Binding HoleItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding HoleIndex}" Width="50"/>
                <DataGridTextColumn Header="圈" Binding="{Binding RingNumber}" Width="50"/>
                <DataGridTextColumn Header="孔序" Binding="{Binding SequenceIndex}" Width="60"/>
                <DataGridTextColumn Header="目标X" Binding="{Binding TargetX, StringFormat=F3}" Width="90"/>
                <DataGridTextColumn Header="目标Y" Binding="{Binding TargetY, StringFormat=F3}" Width="90"/>
                <DataGridTextColumn Header="当前动作状态" Binding="{Binding State}" Width="170"/>
                <DataGridTextColumn Header="补偿值" Binding="{Binding Compensation}" Width="100"/>
                <DataGridTextColumn Header="最近邻采样点(含距离/样本数)" Binding="{Binding NearestSample}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="3" Header="状态时序 / 审计日志" Margin="0,10,0,0">
            <ListBox ItemsSource="{Binding Timeline}" FontFamily="Consolas"/>
        </GroupBox>
    </Grid>
</UserControl>
