<UserControl x:Class="Fredy.Drilling.Holes.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:uc="clr-namespace:Fredy.Drilling.Holes.UserControls"
             xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
             mc:Ignorable="d" 
    
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <ResourceDictionary Source="/Fredy.Drilling.Holes;component/Themes/MainResources.xaml"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource Brush.Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Border Margin="5" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Background="{StaticResource Brush.Background.Subtle}" CornerRadius="6">
            <Grid>
                <uc:CameraViewerControl ImageSource="{Binding CurrentCameraImage}" 
                                        Margin="0,0,0,0"/>

                <TextBlock Text="当前相机图像"
                           Margin="12,10,12,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Foreground="{StaticResource Brush.Foreground}"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <Border Width="340"
                        Height="320"
                        Margin="12"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{StaticResource Brush.Background.Overlay}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <uc:RecipeUserControl RecipeViewModel="{Binding CurrentRecipeViewModel}"/>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1" Grid.RowSpan="2" Margin="5">
            <Border BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" Padding="10" Background="{StaticResource Brush.Background.Subtle}">
                <StackPanel>
                    <TextBlock Text="自动冲孔控制软件" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,3"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>
                        </Grid.Resources>
                        <StackPanel>
                            <TextBlock Text="工件类型:"/>
                            <TextBlock Text="总孔数:"/>
                            <TextBlock Text="当前圈:" Foreground="{StaticResource Brush.Status.Red}" FontWeight="Bold"/>
                            <TextBlock Text="已冲孔:"/>
                            <TextBlock Text="速度:"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <DockPanel LastChildFill="True">
                                <Button Content="刷新" DockPanel.Dock="Right" Margin="10,0,0,0" Padding="8,2" Command="{Binding RefreshRecipesCommand}"/>
                                <ComboBox ItemsSource="{Binding RecipeNames}"
                                          SelectedItem="{Binding Status.WorkpieceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Foreground="{StaticResource Brush.Status.Blue}"
                                          MinWidth="160"/>
                            </DockPanel>
                            <TextBlock Text="{Binding Status.TotalHoles}" Foreground="{StaticResource Brush.Status.Red}" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Status.CurrentRing}" Foreground="{StaticResource Brush.Status.Red}" FontWeight="Bold" Width="40"/>
                                <TextBlock Text="当前孔:" Margin="20,0,0,0" Foreground="{StaticResource Brush.Status.Red}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Status.CurrentHole}" Foreground="{StaticResource Brush.Status.Red}" FontWeight="Bold" Margin="10,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Status.PunchedHoles}" Foreground="{StaticResource Brush.Status.Red}" FontWeight="Bold" Width="40"/>
                                <TextBlock Text="待冲孔:" Margin="20,0,0,0" Foreground="{StaticResource Brush.Status.Red}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Status.RemainingHoles}" Foreground="{StaticResource Brush.Status.Red}" FontWeight="Bold" Margin="10,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Status.Speed}" Foreground="{StaticResource Brush.Status.Blue}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <UniformGrid Columns="1" Margin="0,10">
                <Button Content="校针" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="CameraPunchOffsetCalibration"/>
                <Button Content="参数配置" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Config"/>
                <Button Content="分区扫描" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="PartScan"/>
                <Button Content="配方编辑" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="RecipeWin"/>
                <Button Content="位置校准" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="WorkpieceCenterCalibration"/>
            </UniformGrid>

            <StackPanel Margin="0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                    <CheckBox Content="模拟冲孔" IsChecked="{Binding IsSimulate}" VerticalAlignment="Center" Foreground="{StaticResource Brush.Status.Red}" Margin="0,0,20,0"/>
                    <RadioButton Content="头道" IsChecked="{Binding IsFirstPass}" Margin="0,0,10,0"/>
                    <RadioButton Content="二道"
                                 IsChecked="{Binding IsFirstPass, Converter={StaticResource InverseBoolConverter}}"/>
                </StackPanel>

                <UniformGrid Columns="2">
                    <Button Content="启动冲孔" Background="{StaticResource Brush.Status.Green}" Style="{StaticResource ControlButtonStyle}" Command="{Binding StartPunchingCommand}"/>
                    <Grid>
                        <Button Content="暂停冲孔"
                                Style="{StaticResource ControlButtonStyle}"
                                Command="{Binding PausePunchingCommand}"
                                Visibility="{Binding ShowPausePunchingButton, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="继续冲孔"
                                Background="{StaticResource Brush.Status.Green}"
                                Style="{StaticResource ControlButtonStyle}"
                                Command="{Binding ContinuePunchingCommand}"
                                Visibility="{Binding ShowContinuePunchingButton, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                    <Button Content="自定义" Background="{StaticResource Brush.Status.Yellow}" Style="{StaticResource ControlButtonStyle}" IsEnabled="{Binding CanUseCustomAction}"/>
                    <Button Content="复位" Background="{StaticResource Brush.Status.Yellow}" Style="{StaticResource ControlButtonStyle}" Command="{Binding ResetMachineCommand}"/>
                </UniformGrid>
                <Button Content="停止" Background="{StaticResource Brush.Status.Red}" Foreground="{StaticResource Brush.Foreground}" Height="50" FontSize="20" FontWeight="Bold" Margin="5" Command="{Binding StopPunchingCommand}"/>
            </StackPanel>

            <Border BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1" Margin="5" Padding="5">
                <StackPanel>
                    <TextBlock Text="机台坐标" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="X:"/>
                        <Border Grid.Column="1" Background="{StaticResource Brush.Status.Green}" Margin="2">
                            <TextBlock Text="{Binding Status.PosX, StringFormat=N3}" HorizontalAlignment="Right"/>
                        </Border>
                        <TextBlock Text="Y:" Grid.Row="1"/>
                        <Border Grid.Column="1" Grid.Row="1" Background="{StaticResource Brush.Status.Green}" Margin="2">
                            <TextBlock Text="{Binding Status.PosY, StringFormat=N3}" HorizontalAlignment="Right"/>
                        </Border>
                        <TextBlock Text="Z:" Grid.Row="2"/>
                        <Border Grid.Column="1" Grid.Row="2" Background="{StaticResource Brush.Status.Green}" Margin="2">
                            <TextBlock Text="{Binding Status.PosZ, StringFormat=N3}" HorizontalAlignment="Right"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="操作日志" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Text="共" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Logs.Count}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Brush.Status.Blue}"/>
                <TextBlock Text="/" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LogCapacity}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Brush.Status.Blue}"/>
                <TextBlock Text="条" VerticalAlignment="Center"/>
                <CheckBox Content="仅看 Error/Warning" Margin="12,0,0,0" IsChecked="{Binding OnlyShowWarningsAndErrors}" VerticalAlignment="Center"/>
                <Button Content="导出日志" Margin="10,0" Command="{Binding ExportLogsCommand}" Padding="5,2"/>
                <Button Content="清空日志" Margin="10,0" Command="{Binding ClearLogsCommand}" Padding="5,2"/>
            </StackPanel>
            <ListBox x:Name="LogListBox"
                     Grid.Row="1"
                     ItemsSource="{Binding FilteredLogs}"
                     Background="{StaticResource Brush.Background.Subtle}"
                     BorderBrush="{StaticResource Brush.Border}"
                     BorderThickness="1"
                     Loaded="LogListBox_Loaded"
                     Unloaded="LogListBox_Unloaded">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,1" Padding="4,2" Background="{Binding Background}">
                            <TextBlock Text="{Binding DisplayText}" Foreground="{Binding Foreground}" FontFamily="Consolas" TextWrapping="Wrap"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <StatusBar Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource Brush.Background.Subtle}">
            <StatusBarItem Content="自动冲孔机控制系统"/>
            <Separator/>
            <StatusBarItem Content="软件版本 1.0.1"/>
            <Separator/>
            <TextBlock Text="运动控制卡状态"/>
            <Border Background="{Binding Status.IsMotionCardReady, Converter={StaticResource StatusColorConverter}}" Padding="5,1">
                <TextBlock Text="未就绪"/>
            </Border>
            <Separator/>
            <TextBlock Text="相机状态"/>
            <Border Background="{Binding Status.IsCameraConnected, Converter={StaticResource StatusColorConverter}}" Padding="5,1">
                <TextBlock Foreground="{StaticResource Brush.Foreground}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="未连接"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status.IsCameraConnected}" Value="True">
                                    <Setter Property="Text" Value="已连接"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </StatusBar>
    </Grid>
</UserControl>
