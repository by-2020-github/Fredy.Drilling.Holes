<UserControl
    x:Class="Fredy.Drilling.Holes.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Fredy.Drilling.Holes.UserControls"
    xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary Source="/Fredy.Drilling.Holes;component/Themes/MainResources.xaml" />
    </UserControl.Resources>

    <Grid Background="{StaticResource Brush.Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="250" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border
            Margin="5"
            Background="{StaticResource Brush.Background.Subtle}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="6">
            <Grid>
                <uc:CameraViewerControl
                    x:Name="MainCameraViewer"
                    Margin="0,0,0,0"
                    ImageSource="{Binding CurrentCameraImage}" />



                <Border
                    Width="340"
                    Height="320"
                    Margin="12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource Brush.Background.Overlay}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <uc:RecipeUserControl RecipeViewModel="{Binding CurrentRecipeViewModel}" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.RowSpan="3"
            Grid.Column="1"
            Margin="5"
            CanContentScroll="True"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="OpPanel">
                <Border
                    Padding="10"
                    Background="{StaticResource Brush.Background.Subtle}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,10"
                            FontSize="20"
                            FontWeight="Bold"
                            Text="自动冲孔控制软件" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="0,3" />
                                    <Setter Property="FontSize" Value="14" />
                                </Style>
                            </Grid.Resources>
                            <StackPanel>
                                <TextBlock Text="工件类型:" />
                                <TextBlock Text="总孔数:" />
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="{StaticResource Brush.Status.Red}"
                                    Text="当前圈:" />
                                <TextBlock Text="已冲孔:" />
                                <TextBlock Text="速度:" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <DockPanel LastChildFill="True">
                                    <Button
                                        Margin="10,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding RefreshRecipesCommand}"
                                        Content="刷新"
                                        DockPanel.Dock="Right" />
                                    <ComboBox
                                        MinWidth="160"
                                        Foreground="{StaticResource Brush.Status.Blue}"
                                        ItemsSource="{Binding RecipeNames}"
                                        SelectedItem="{Binding Status.WorkpieceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                                <TextBlock
                                    FontWeight="Bold"
                                    Foreground="{StaticResource Brush.Status.Red}"
                                    Text="{Binding Status.TotalHoles}" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Width="40"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource Brush.Status.Red}"
                                        Text="{Binding Status.CurrentRing}" />
                                    <TextBlock
                                        Margin="20,0,0,0"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource Brush.Status.Red}"
                                        Text="当前孔:" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource Brush.Status.Red}"
                                        Text="{Binding Status.CurrentHole}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Width="40"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource Brush.Status.Red}"
                                        Text="{Binding Status.PunchedHoles}" />
                                    <TextBlock
                                        Margin="20,0,0,0"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource Brush.Status.Red}"
                                        Text="待冲孔:" />
                                    <TextBlock
                                        Margin="10,0,0,0"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource Brush.Status.Red}"
                                        Text="{Binding Status.RemainingHoles}" />
                                </StackPanel>
                                <TextBlock Foreground="{StaticResource Brush.Status.Blue}" Text="{Binding Status.Speed}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <UniformGrid Margin="0,10" Columns="1">
                    <Button
                        Click="NavigationButton_Click"
                        CommandParameter="Config"
                        Content="参数配置"
                        Style="{StaticResource NavButtonStyle}" />
                    <Button
                        Click="NavigationButton_Click"
                        CommandParameter="PartScan"
                        Content="分区扫描"
                        Style="{StaticResource NavButtonStyle}" />
                    <Button
                        Click="NavigationButton_Click"
                        CommandParameter="RecipeWin"
                        Content="配方编辑"
                        Style="{StaticResource NavButtonStyle}" />
                    <Button
                        Click="NavigationButton_Click"
                        CommandParameter="CameraPunchOffsetCalibration"
                        Content="校针"
                        Style="{StaticResource NavButtonStyle}" />
                    <Button
                        Click="NavigationButton_Click"
                        CommandParameter="WorkpieceCenterCalibration"
                        Content="位置校准(圆心）"
                        Style="{StaticResource NavButtonStyle}" />
                </UniformGrid>

                <StackPanel Margin="0,10">
                    <StackPanel
                        Margin="0,5"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <CheckBox
                            Margin="0,0,20,0"
                            VerticalAlignment="Center"
                            Content="模拟冲孔"
                            Foreground="{StaticResource Brush.Status.Red}"
                            IsChecked="{Binding IsSimulate}" />
                        <RadioButton
                            Margin="0,0,10,0"
                            Content="头道"
                            IsChecked="{Binding IsFirstPass}" />
                        <RadioButton Content="二道" IsChecked="{Binding IsFirstPass, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>

                    <UniformGrid Columns="2">
                        <Button
                            Background="{StaticResource Brush.Status.Green}"
                            Command="{Binding StartPunchingCommand}"
                            Content="启动冲孔"
                            Style="{StaticResource ControlButtonStyle}" />
                        <Grid>
                            <Button
                                Command="{Binding PausePunchingCommand}"
                                Content="暂停冲孔"
                                Style="{StaticResource ControlButtonStyle}"
                                Visibility="{Binding ShowPausePunchingButton, Converter={StaticResource BoolToVis}}" />
                            <Button
                                Background="{StaticResource Brush.Status.Green}"
                                Command="{Binding ContinuePunchingCommand}"
                                Content="继续冲孔"
                                Style="{StaticResource ControlButtonStyle}"
                                Visibility="{Binding ShowContinuePunchingButton, Converter={StaticResource BoolToVis}}" />
                        </Grid>
                        <Button
                            Background="{StaticResource Brush.Status.Yellow}"
                            Command="{Binding CustomPunchingCommand}"
                            Content="自定义"
                            IsEnabled="{Binding CanUseCustomAction}"
                            Style="{StaticResource ControlButtonStyle}" />
                        <Button
                            Background="{StaticResource Brush.Status.Yellow}"
                            Command="{Binding ResetMachineCommand}"
                            Content="复位"
                            Style="{StaticResource ControlButtonStyle}" />
                    </UniformGrid>
                    <Button
                        Height="50"
                        Margin="5"
                        Background="{StaticResource Brush.Status.Red}"
                        Command="{Binding StopPunchingCommand}"
                        Content="停止"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{StaticResource Brush.Foreground}" />
                </StackPanel>

                <Expander
                    Margin="0,4,0,0"
                    Header="临时双点冲孔测试"
                    IsExpanded="False">
                    <Border
                        Margin="0,6,0,0"
                        Padding="10"
                        Background="{StaticResource Brush.Background.Subtle}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                Foreground="{StaticResource Brush.Foreground.Secondary}"
                                Text="按机台绝对坐标直接执行两点测试；每个点固定下探 3 次，单次高度可调，SafeZ/下压速度采用全局 AppConfig，不走配方流程。"
                                TextWrapping="Wrap" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,8,8"
                                    VerticalAlignment="Center"
                                    Text="第1点 X" />
                                <hc:NumericUpDown
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,10,8"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding TemporaryTestStartX, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="0,0,8,8"
                                    VerticalAlignment="Center"
                                    Text="第1点 Y" />
                                <hc:NumericUpDown
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding TemporaryTestStartY, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,0,8,8"
                                    VerticalAlignment="Center"
                                    Text="第2点 X" />
                                <hc:NumericUpDown
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,0,10,8"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding TemporaryTestPunchX, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,0,8,8"
                                    VerticalAlignment="Center"
                                    Text="第2点 Y" />
                                <hc:NumericUpDown
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Margin="0,0,0,8"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding TemporaryTestPunchY, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Text="单次下探" />
                                <hc:NumericUpDown
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,0,10,0"
                                    Minimum="0.001"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding TemporaryTestPunchStepDepth, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="2"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text="固定每点 3 次" />
                            </Grid>

                            <StackPanel HorizontalAlignment="Stretch" Orientation="Horizontal">
                                <Button
                                    Width="130"
                                    Background="{StaticResource Brush.Status.Green}"
                                    Command="{Binding StartTemporaryPunchTestCommand}"
                                    Content="开始测试"
                                    Style="{StaticResource ControlButtonStyle}" />
                                <Button
                                    Width="130"
                                    Margin="10,0,0,0"
                                    Background="{StaticResource Brush.Status.Red}"
                                    Command="{Binding StopTemporaryPunchTestCommand}"
                                    Content="停止测试"
                                    Foreground="{StaticResource Brush.Foreground}"
                                    Style="{StaticResource ControlButtonStyle}" />
                            </StackPanel>

                            <TextBlock
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource Brush.Status.Blue}"
                                Text="{Binding TemporaryPunchTestStatus}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="操作日志" />
                <TextBlock
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Text="共" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Foreground="{StaticResource Brush.Status.Blue}"
                    Text="{Binding Logs.Count}" />
                <TextBlock VerticalAlignment="Center" Text="/" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Foreground="{StaticResource Brush.Status.Blue}"
                    Text="{Binding LogCapacity}" />
                <TextBlock VerticalAlignment="Center" Text="条" />
                <CheckBox
                    Margin="12,0,4,0"
                    VerticalAlignment="Center"
                    Content="Verbose"
                    Foreground="DimGray"
                    IsChecked="{Binding ShowVerbose}" />
                <CheckBox
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    Content="Debug"
                    Foreground="SlateGray"
                    IsChecked="{Binding ShowDebug}" />
                <CheckBox
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    Content="Info"
                    IsChecked="{Binding ShowInformation}" />
                <CheckBox
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    Content="Warning"
                    Foreground="DarkOrange"
                    IsChecked="{Binding ShowWarning}" />
                <CheckBox
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    Content="Error"
                    Foreground="Crimson"
                    IsChecked="{Binding ShowError}" />
                <CheckBox
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    Content="Fatal"
                    Foreground="Crimson"
                    IsChecked="{Binding ShowFatal}" />
                <Button
                    Margin="10,0"
                    Padding="5,2"
                    Command="{Binding ExportLogsCommand}"
                    Content="导出日志" />
                <Button
                    Margin="10,0"
                    Padding="5,2"
                    Command="{Binding ClearLogsCommand}"
                    Content="清空日志" />
            </StackPanel>
            <ListBox
                x:Name="LogListBox"
                Grid.Row="1"
                Background="{StaticResource Brush.Background.Subtle}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                ItemsSource="{Binding FilteredLogs}"
                Loaded="LogListBox_Loaded"
                Unloaded="LogListBox_Unloaded">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,1"
                            Padding="4,2"
                            Background="{Binding Background}">
                            <TextBlock
                                FontFamily="Consolas"
                                Foreground="{Binding Foreground}"
                                Text="{Binding DisplayText}"
                                TextWrapping="Wrap" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <StatusBar
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="{StaticResource Brush.Background.Subtle}">
            <StatusBarItem Content="自动冲孔机控制系统" />
            <Separator />
            <StatusBarItem Content="软件版本 1.0.1" />
            <Separator />
            <TextBlock Text="运动控制卡状态" />
            <Border Padding="5,1" Background="{Binding Status.IsMotionCardReady, Converter={StaticResource StatusColorConverter}}">
                <TextBlock Text="未就绪" />
            </Border>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        FontWeight="Bold"
                        Text="机台坐标" />
                    <TextBlock Text="X:" />
                    <TextBlock
                        Margin="4,0,12,0"
                        FontWeight="Bold"
                        Text="{Binding Status.PosX, StringFormat=N3}" />
                    <TextBlock Text="Y:" />
                    <TextBlock
                        Margin="4,0,12,0"
                        FontWeight="Bold"
                        Text="{Binding Status.PosY, StringFormat=N3}" />
                    <TextBlock Text="Z:" />
                    <TextBlock
                        Margin="4,0,0,0"
                        FontWeight="Bold"
                        Text="{Binding Status.PosZ, StringFormat=N3}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <TextBlock Text="相机状态" />
            <Border Padding="5,1" Background="{Binding Status.IsCameraConnected, Converter={StaticResource StatusColorConverter}}">
                <TextBlock Foreground="{StaticResource Brush.Foreground}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="未连接" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status.IsCameraConnected}" Value="True">
                                    <Setter Property="Text" Value="已连接" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </StatusBar>
    </Grid>
</UserControl>
