<Window x:Class="Fredy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
     xmlns:views="clr-namespace:Fredy.Drilling.Holes.Views"
        mc:Ignorable="d"
        MaxHeight="1024" MaxWidth="1280"
        Title="冲孔软件" Height="1024" Width="1280">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="复位">
            <MenuItem Header="复位 (X/Y)" Command="{Binding ResetCommand}"/>
            <MenuItem Header="复位 X" Command="{Binding ResetXCommand}"/>
            <MenuItem Header="复位 Y" Command="{Binding ResetYCommand}"/>
            <MenuItem Header="复位 Z" Command="{Binding ResetZCommand}"/>
            </MenuItem>
            <MenuItem Header="取消复位" Command="{Binding CancelResetCommand}"/>
            <Separator/>
            <MenuItem Header="急停" Command="{Binding EmergencyStopCommand}"
                  Foreground="Red" FontWeight="Bold"/>
        </Menu>

        <views:MainView Grid.Row="1"/>
    </Grid>
</Window>
