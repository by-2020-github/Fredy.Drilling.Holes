<Window x:Class="Fredy.Drilling.Holes.Views.CenterRoiBinarySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
        Title="中心ROI二值化参数"
        Height="680"
        Width="960"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background.Subtle}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Margin="5" Background="{StaticResource Brush.Surface.Dark}" BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1">
                <Grid>
                    <TextBlock Text="原始图像" Foreground="{StaticResource Brush.Foreground.Inverse}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5" Background="{StaticResource Brush.Surface.DarkAlt}" Padding="4"/>
                    <Image x:Name="ImageOriginal" Stretch="Uniform"/>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Margin="5" Background="{StaticResource Brush.Surface.Dark}" BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1">
                <Grid>
                    <TextBlock Text="中心ROI原图" Foreground="{StaticResource Brush.Foreground.Inverse}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5" Background="{StaticResource Brush.Surface.DarkAlt}" Padding="4"/>
                    <Image x:Name="ImageRoi" Stretch="Uniform"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" Background="{StaticResource Brush.Surface.Dark}" BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1">
                <Grid>
                    <TextBlock Text="中心ROI二值化结果" Foreground="{StaticResource Brush.Foreground.Inverse}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5" Background="{StaticResource Brush.Surface.DarkAlt}" Padding="4"/>
                    <Image x:Name="ImageBinary" Stretch="Uniform"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Column="1">
            <TextBlock Text="调整中心ROI大小和二值化参数，左侧将实时预览。" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="{StaticResource Brush.Foreground.Muted}"/>

            <GroupBox Header="中心ROI参数" Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="ROI宽度(px):" FontWeight="Medium"/>
                    <hc:NumericUpDown Value="{Binding RoiWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="4096" DecimalPlaces="0" Increment="1" Margin="0,5,0,10" Style="{StaticResource NumericIntUpDownStyle}"/>

                    <TextBlock Text="ROI高度(px):" FontWeight="Medium"/>
                    <hc:NumericUpDown Value="{Binding RoiHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="4096" DecimalPlaces="0" Increment="1" Margin="0,5,0,10" Style="{StaticResource NumericIntUpDownStyle}"/>

                    <TextBlock Text="二值化阈值(0-255):" FontWeight="Medium"/>
                    <hc:NumericUpDown Value="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="255" DecimalPlaces="0" Increment="1" Margin="0,5,0,10" Style="{StaticResource NumericIntUpDownStyle}"/>

                    <CheckBox Content="反相二值化(BinaryInv)" IsChecked="{Binding Invert, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"/>
                </StackPanel>
            </GroupBox>

            <Button Content="应用为全局参数" Height="45" Margin="0,0,0,10" Click="ApplyButton_Click" Background="{StaticResource Brush.Status.Green}" Foreground="{StaticResource Brush.Foreground.Inverse}" FontSize="16" FontWeight="Bold"/>
            <Button Content="取消 / 关闭" Height="35" Click="CancelButton_Click" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
