<Window x:Class="Fredy.Drilling.Holes.Views.WorkpieceCenterCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
        xmlns:uc="clr-namespace:Fredy.Drilling.Holes.UserControls"
        mc:Ignorable="d" x:Name="thisWin"
        MaxHeight="1024" MaxWidth="1280" Height="Auto" 
        Title="工件圆心校准" Width="1050" Background="{StaticResource Brush.Background.Subtle}"
        d:DataContext="{d:DesignInstance Type=vm:WorkpieceCenterCalibrationViewModel, IsDesignTimeCreatable=True}">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <Grid Height="160" Width="260" HorizontalAlignment="Left" Margin="20,0,0,0">
                <Button Content="X-" Background="{StaticResource Brush.Status.Yellow}" HorizontalAlignment="Left" VerticalAlignment="Center" Width="65" Height="65" FontSize="20" FontWeight="Bold" Command="{Binding MoveAxisCommand}" CommandParameter="X-"/>
                <Button Content="X+" Background="{StaticResource Brush.Status.Yellow}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="65" Height="65" FontSize="20" FontWeight="Bold" Command="{Binding MoveAxisCommand}" CommandParameter="X+"/>
                <Button Content="Y+" Background="{StaticResource Brush.Status.Green}" HorizontalAlignment="Center" VerticalAlignment="Top" Width="65" Height="65" FontSize="20" FontWeight="Bold" Command="{Binding MoveAxisCommand}" CommandParameter="Y+"/>
                <Button Content="Y-" Background="{StaticResource Brush.Status.Green}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="65" Height="65" FontSize="20" FontWeight="Bold" Command="{Binding MoveAxisCommand}" CommandParameter="Y-"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,20">
                <TextBlock Text="点动步距：" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <ComboBox Width="180" Height="40" FontSize="20" VerticalContentAlignment="Center"
                          ItemsSource="{Binding JogStepOptions}" SelectedItem="{Binding JogStep}"/>
            </StackPanel>

            <Border Margin="0,0,0,10"
                    Padding="10"
                    BorderBrush="{StaticResource Brush.Border.Strong}"
                    BorderThickness="1"
                    Background="{StaticResource Brush.Status.Blue.Subtle}">
                <StackPanel>
                    <TextBlock Text="图像区右键支持两种方式：1. 框选中心圆孔 ROI 自动识别圆心；2. 开启边缘点自动拾取后，点击圆边附近自动寻边并记录。"
                               TextWrapping="Wrap"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding InteractionStatus}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Brush.Status.Blue}"/>
                </StackPanel>
            </Border>

            <GroupBox Header="坐标点记录" Margin="0,10" Background="{StaticResource Brush.Background.Subtle}">
                <StackPanel Margin="5">
                    <TextBlock Text="人工移动相机十字到边缘，记录 3 个或以上点位：" TextWrapping="Wrap" Margin="0,0,0,10" FontSize="14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="记录边缘点" Height="40" FontSize="18" Margin="5" Command="{Binding RecordEdgePointCommand}" Background="{StaticResource Brush.Status.Blue.Subtle}"/>
                        <Button Grid.Column="1" Content="清空记录" Height="40" FontSize="18" Margin="5" Command="{Binding ClearPointsCommand}" Background="{StaticResource Brush.Status.Red.Subtle}"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding EdgePoints}" AutoGenerateColumns="False" Height="150" Margin="5" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="X 坐标" Binding="{Binding X, StringFormat={}{0:F3}}" Width="*"/>
                            <DataGridTextColumn Header="Y 坐标" Binding="{Binding Y, StringFormat={}{0:F3}}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Content="计算圆心" Height="45" FontSize="20" FontWeight="Bold" Margin="5,10,5,5" Command="{Binding FitCircleCommand}" Background="{StaticResource Brush.Status.Green.Subtle}"/>

                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 相机对准圆心时的机械坐标（原始拟合值） -->
                        <TextBlock Text="相机圆心坐标：" FontSize="15" FontWeight="Bold"
                                   Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource Brush.Status.Blue}"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="{Binding CameraAtWorkpieceCenterX, StringFormat=X: {0:F3}}"
                                       Foreground="{StaticResource Brush.Status.Blue}" FontSize="15" FontWeight="Bold" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding CameraAtWorkpieceCenterY, StringFormat=Y: {0:F3}}"
                                       Foreground="{StaticResource Brush.Status.Blue}" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- 冲针/工件坐标系圆心（= 相机圆心 − CameraToPunchOffset） -->
                        <TextBlock Text="冲针圆心坐标：" FontSize="15" FontWeight="Bold"
                                   Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.Status.Red}"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Margin="10,8,0,0">
                            <TextBlock Text="{Binding CalculatedCenterX, StringFormat=X: {0:F3}}"
                                       Foreground="{StaticResource Brush.Status.Red}" FontSize="15" FontWeight="Bold" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding CalculatedCenterY, StringFormat=Y: {0:F3}}"
                                       Foreground="{StaticResource Brush.Status.Red}" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- 拟合半径 -->
                        <TextBlock Text="计算所得半径：" FontSize="15" FontWeight="Bold"
                                   Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CalculatedRadius, StringFormat=R: {0:F3}}"
                                   Foreground="{StaticResource Brush.Status.Red}" FontSize="15" FontWeight="Bold"
                                   Grid.Row="2" Grid.Column="1" Margin="10,8,0,0"/>
                    </Grid>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Grid Grid.Column="1">
            <Border BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1" Background="{StaticResource Brush.Background.Disabled}">
                <uc:CameraViewerControl x:Name="CalibrationCameraViewer" ShowWorkpieceCalibrationTools="True" ImageMat="{Binding CameraPreviewMat}" />
            </Border>
        </Grid>
    </Grid>
</Window>
