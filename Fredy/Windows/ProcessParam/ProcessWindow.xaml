<Window x:Class="Fredy.Drilling.Holes.Views.ProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
        xmlns:models="clr-namespace:Fredy.Drilling.Holes.Models"
        mc:Ignorable="d" x:Name="thisWin"
        Title="工艺参数" Height="600" Width="1100" Background="#F0F0F0"
        d:DataContext="{d:DesignInstance Type=vm:ProcessViewModel, IsDesignTimeCreatable=True}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0">
            <GroupBox Header="工件参数" Margin="0,0,0,15" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="工件类型" FontSize="18" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <ComboBox ItemsSource="{Binding WorkpieceTypes}" 
                              SelectedItem="{Binding Data.WorkpieceType}" 
                              Width="550" Height="35" FontSize="16" VerticalContentAlignment="Center"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="头道参数" Margin="0,0,0,15" Padding="15">
                <UniformGrid Columns="2">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="头道冲孔深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox Text="{Binding Data.FirstPunchDepth}" Width="100" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="头道啄孔深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox Text="{Binding Data.FirstPeckDepth}" Width="100" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="断针报警深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox Text="{Binding Data.FirstAlarmDepth}" Width="100" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="啄孔单次深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox Text="{Binding Data.FirstPeckSingleDepth}" Width="100" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="头道抬起高度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox Text="{Binding Data.FirstLiftHeight}" Width="100" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>
            </GroupBox>

            <GroupBox Header="二道参数" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="头道冲孔深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                            <TextBox Text="{Binding Data.SecondPunchDepth}" Width="100" Height="30"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="断针报警深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                            <TextBox Text="{Binding Data.SecondAlarmDepth}" Width="100" Height="30"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="头道抬起高度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                            <TextBox Text="{Binding Data.SecondLiftHeight}" Width="100" Height="30"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="最低安全深度" Width="110" VerticalAlignment="Center" FontSize="16"/>
                            <TextBox Text="{Binding Data.MinSafeDepth}" Width="100" Height="30"/>
                        </StackPanel>
                        <CheckBox Content="二道检测" IsChecked="{Binding Data.IsSecondDetectionActive}" 
                                  FontSize="16" Margin="110,15,0,0"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </StackPanel>

        <GroupBox Grid.Column="1" Header="冲孔深度" Margin="15,0,0,0">
            <ItemsControl ItemsSource="{Binding Data.PunchDepths}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:DepthItem}">
                        <StackPanel Orientation="Horizontal" Margin="5,4">
                            <TextBlock Text="{Binding Label}" Width="40" VerticalAlignment="Center" FontSize="16"/>
                            <TextBox Text="{Binding Value}" Width="80" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Padding="5,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </GroupBox>

        <Button Grid.Row="1" Grid.ColumnSpan="2" Content="应用并关闭" 
                Background="#7FFF00" FontSize="20" FontWeight="Bold" Width="160" Height="45"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Command="{Binding ApplyAndCloseCommand}" 
                CommandParameter="{Binding ElementName=thisWin}"/>
    </Grid>
</Window>