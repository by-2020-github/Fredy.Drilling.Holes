<Window x:Class="Fredy.Drilling.Holes.Views.ScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
        mc:Ignorable="d"
        MaxHeight="1024" MaxWidth="1280"
        Title="分区扫描" Height="700" Width="1100" Background="#F0F0F0"
        d:DataContext="{d:DesignInstance Type=vm:ScanViewModel, IsDesignTimeCreatable=True}">

    <Window.Resources>
        <Style x:Key="GridCellPresenterStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="工件类型：" FontSize="16"/>
                        <TextBlock Text="{Binding Params.WorkpieceType}" Foreground="RoyalBlue" FontSize="16"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="工件直径(mm)：" FontSize="16"/>
                        <TextBox Text="{Binding Params.WorkpieceDiameter, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="6,0,0,0"/>
                    </StackPanel>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="FOV大小(mm):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Text="{Binding Params.FovSize}"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 Background="#F3F3F3"
                                 Margin="2"/>

                        <TextBlock Grid.Row="1" Text="扫描扩展(mm):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Params.ScanExpand, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>

                        <TextBlock Grid.Row="2" Text="列重叠(% 5~20):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Params.OverlapXPercent, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>

                        <TextBlock Grid.Row="3" Text="行重叠(% 5~20):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Params.OverlapYPercent, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>

                        <TextBlock Grid.Row="4" Text="稳定时间(ms):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Params.SettleTime, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,20">
                    <Button Content="计算扫描坐标" Height="46" Background="#E9967A"
                            FontSize="17" FontWeight="Bold" Command="{Binding CalculateCoordinatesCommand}"/>

                    <UniformGrid Columns="2" Margin="0,14,0,0">
                        <Button Content="开始Z字扫描" Height="42" Margin="0,0,5,0" Command="{Binding StartScanCommand}"/>
                        <Button Content="停止扫描" Height="42" Margin="5,0,0,0" Command="{Binding StopScanCommand}"/>
                    </UniformGrid>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,10">
                    <TextBlock Text="扫描输出" FontWeight="Bold" FontSize="15" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Params.ScanStatus}" FontSize="14" Margin="0,2"/>
                    <TextBlock Text="{Binding Params.PhotoIndex, StringFormat=拍照序号：{0}}" FontSize="14" Margin="0,2"/>
                    <TextBlock Text="{Binding Params.CurrentX, StringFormat='当前位置：X={0:F3}'}" FontSize="14" Margin="0,2"/>
                    <TextBlock Text="{Binding Params.CurrentY, StringFormat='          Y={0:F3}'}" FontSize="14" Margin="0,2"/>
                    <TextBlock Text="{Binding Params.RowCount, StringFormat='网格：{0} 行'}" FontSize="14" Margin="0,2"/>
                    <TextBlock Text="{Binding Params.ColumnCount, StringFormat='      {0} 列'}" FontSize="14" Margin="0,2"/>
                    <TextBlock Text="{Binding Params.TotalShots, StringFormat='总点数：{0}'}" FontSize="14" Margin="0,2"/>
                    <TextBlock Text="{Binding Params.ActualOverlapXPercent, StringFormat='列重叠：{0:F1}%'}" FontSize="14" Margin="0,2"/>
                    <TextBlock Text="{Binding Params.ActualOverlapYPercent, StringFormat='行重叠：{0:F1}%'}" FontSize="14" Margin="0,2"/>
                    <ProgressBar Height="18" Margin="0,10,0,0" Value="{Binding Params.ProgressValue}" Maximum="100" Foreground="LimeGreen"/>
                </StackPanel>

                <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                    <TextBlock Text="说明：" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Text="1) 扫描范围=工件直径+2*扩展；扩展默认约1个FOV，并限制在1~2个FOV。" TextWrapping="Wrap" Opacity="0.85"/>
                    <TextBlock Text="2) 行列重叠率限制为5%~20%，并采用Z字形软触发路径。" TextWrapping="Wrap" Opacity="0.85"/>
                    <TextBlock Text="3) 右侧显示拼接预览与网格叠加，绿色=已扫，黄色=未扫。" TextWrapping="Wrap" Opacity="0.85"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#111111" Margin="8" Padding="8">
            <Grid>
                <Image Source="{Binding StitchedPreviewImage}" Stretch="Uniform"/>

                <ItemsControl Width="{Binding PreviewCanvasSize}"
                              Height="{Binding PreviewCanvasSize}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Opacity="0.2"
                              ItemsSource="{Binding PreviewGridCells}"
                              ItemContainerStyle="{StaticResource GridCellPresenterStyle}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="{Binding Width}" Height="{Binding Height}">
                                <Rectangle Fill="Transparent"
                                           Stroke="{Binding Stroke}"
                                           StrokeThickness="2"/>
                                <TextBlock Text="{Binding OrderLabel}"
                                           Foreground="{Binding LabelBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="扫描拼接预览（网格透明叠加）"
                           Foreground="#B0B0B0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Margin="8,4"/>
            </Grid>
        </Border>
    </Grid>
</Window>