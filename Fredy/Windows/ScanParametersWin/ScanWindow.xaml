<Window x:Class="Fredy.Drilling.Holes.Views.ScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
        mc:Ignorable="d"
        Title="分区扫描" Height="700" Width="1000" Background="#F0F0F0"
        d:DataContext="{d:DesignInstance Type=vm:ScanViewModel, IsDesignTimeCreatable=True}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="工件类型：" FontSize="16"/>
                        <TextBlock Text="{Binding Params.WorkpieceType}" Foreground="RoyalBlue" FontSize="16"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="工件直径：" FontSize="16"/>
                        <TextBlock Text="{Binding Params.Diameter}" Foreground="Coral" FontSize="16"/>
                    </StackPanel>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="视野大小(mm):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Params.FovSize}" Margin="2"/>

                        <TextBlock Grid.Row="1" Text="扫描区扩展(mm):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Params.ScanExpand}" Margin="2"/>

                        <TextBlock Grid.Row="2" Text="机台稳定时间(ms):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Params.SettleTime}" Margin="2"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,20">
                    <Button Content="计算扫描坐标" Height="50" Background="#E9967A" 
                            FontSize="18" FontWeight="Bold" Command="{Binding CalculateCoordinatesCommand}"/>

                    <UniformGrid Columns="2" Margin="0,20,0,0">
                        <Button Content="开始分区扫描" Height="50" Margin="0,0,5,0" Command="{Binding StartScanCommand}"/>
                        <Button Content="停止扫描" Height="50" Margin="5,0,0,0" Command="{Binding StopScanCommand}"/>
                    </UniformGrid>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="扫描状态：" FontSize="16"/>
                        <TextBlock Text="{Binding Params.ScanStatus}" FontSize="16"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="拍照序号：" FontSize="16"/>
                        <TextBlock Text="{Binding Params.PhotoIndex}" FontSize="16"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="当前位置：" FontSize="16"/>
                        <TextBlock Text="{Binding Params.CurrentX, StringFormat='X:{0:F3}'}" FontSize="16"/>
                        <TextBlock Text="{Binding Params.CurrentY, StringFormat=', Y:{0:F3}'}" FontSize="16"/>
                    </StackPanel>
                    <ProgressBar Height="20" Margin="0,10" Value="{Binding Params.ProgressValue}" Foreground="LimeGreen"/>
                </StackPanel>

                <Grid Grid.Row="3" VerticalAlignment="Bottom">
                    <StackPanel>
                        <TextBlock Text="使用说明：" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Text="1.设置拍照间距和扩展距离；" TextWrapping="Wrap" Opacity="0.8"/>
                        <TextBlock Text="2.点击计算扫描坐标，计算完成后再点击开始分区扫描；" TextWrapping="Wrap" Opacity="0.8"/>
                        <TextBlock Text="3.等待扫描完成，再进行后面坐标计算。" TextWrapping="Wrap" Opacity="0.8"/>
                    </StackPanel>
                    <Button Content="测试" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="60" Height="30" Command="{Binding TestCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="Black" Margin="5">
            <TextBlock Text="扫描实时画面预览" Foreground="DimGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>