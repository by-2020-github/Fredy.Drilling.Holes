<Window x:Class="Fredy.Drilling.Holes.Views.ManualControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
             xmlns:models="clr-namespace:Fredy.Drilling.Holes.Models"
             xmlns:uc="clr-namespace:Fredy.Drilling.Holes.UserControls"
             mc:Ignorable="d" Background="#F0F0F0"
             d:DesignHeight="700" d:DesignWidth="1100"
            MaxHeight="1024" MaxWidth="1280" Height="Auto" 
             Title="手动控制"
             d:DataContext="{d:DesignInstance Type=vm:ManualControlViewModel, IsDesignTimeCreatable=True}">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <Grid Height="180">
                <Grid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="FontSize" Value="20"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Margin" Value="5"/>
                    </Style>
                </Grid.Resources>
                <Button Content="X-" Background="#A68D85" HorizontalAlignment="Left" VerticalAlignment="Center" Width="70" Height="70" Command="{Binding MoveAxisCommand}" CommandParameter="X-"/>
                <Button Content="X+" Background="#A68D85" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,100,0" Width="70" Height="70" Command="{Binding MoveAxisCommand}" CommandParameter="X+"/>
                <Button Content="Y+" Background="#8EB933" HorizontalAlignment="Center" VerticalAlignment="Top" Width="70" Height="70" Margin="0,0,80,0" Command="{Binding MoveAxisCommand}" CommandParameter="Y+"/>
                <Button Content="Y-" Background="#8EB933" HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="70" Height="70" Margin="0,0,80,0" Command="{Binding MoveAxisCommand}" CommandParameter="Y-"/>
                <Button Content="Z+" Background="#8F78C6" HorizontalAlignment="Right" VerticalAlignment="Top" Width="70" Height="70" Command="{Binding MoveAxisCommand}" CommandParameter="Z+"/>
                <Button Content="Z-" Background="#8F78C6" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="70" Height="70" Command="{Binding MoveAxisCommand}" CommandParameter="Z-"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,20">
                <TextBlock Text="点动步距：" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <ComboBox Width="200" Height="40" FontSize="20" ItemsSource="{Binding JogStepOptions}" SelectedItem="{Binding JogStep}"/>
            </StackPanel>

            <GroupBox Header="GPIO_IN" Margin="0,15">
                <ItemsControl ItemsSource="{Binding GpioIn}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:GpioItem}">
                            <Border BorderBrush="Gray" BorderThickness="1" Margin="1" Height="25"
                                    Background="{Binding IsActive, Converter={StaticResource StatusColorConverter}}">
                                <TextBlock Text="{Binding Id}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <GroupBox Header="GPIO_OUT" Margin="0,5">
                <ItemsControl ItemsSource="{Binding GpioOut}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:GpioItem}">
                            <Button Width="30"
                                    Height="25"
                                    Margin="2"
                                    Padding="0"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    Background="{Binding IsActive, Converter={StaticResource StatusColorConverter}}"
                                    Command="{Binding DataContext.ToggleOutputCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Id}">
                                <TextBlock Text="{Binding Id}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <TextBlock Text="机台坐标" FontSize="20" FontWeight="Bold" Margin="0,15,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="X:" FontSize="24" Margin="0,5"/>
                    <TextBlock Text="Y:" FontSize="24" Margin="0,5"/>
                    <TextBlock Text="Z:" FontSize="24" Margin="0,5"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0">
                    <Border Background="#00FF00" Margin="0,5" Height="35">
                        <TextBlock Text="{Binding MachineStatus.PosX, StringFormat=N3}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#00FF00" Margin="0,5" Height="35">
                        <TextBlock Text="{Binding MachineStatus.PosY, StringFormat=N3}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#00FF00" Margin="0,5" Height="35">
                        <TextBlock Text="{Binding MachineStatus.PosZ, StringFormat=N3}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="未回零" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="X轴回零" Width="100" Command="{Binding HomeAxisCommand}" CommandParameter="X"/>
                    </StackPanel>
                    <Button Content="Y轴回零" Width="100" Margin="50,5,0,5" Command="{Binding HomeAxisCommand}" CommandParameter="Y"/>
                    <Button Content="Z轴回零" Width="100" Margin="50,5,0,5" Command="{Binding HomeAxisCommand}" CommandParameter="Z"/>
                </StackPanel>
            </Grid>

            <GroupBox Header="坐标偏差校准 (Offset)" Margin="0,15" Background="#F8F8F8">
                <StackPanel Margin="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="1. 记录冲针" FontSize="16" Height="40" Margin="5" Command="{Binding MarkPunchPositionCommand}"/>
                        <Button Grid.Column="1" Content="打孔" FontSize="16" Height="40" Margin="5" Command="{Binding TestPunchCommand}" Background="#FFDDDD"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding PunchX, StringFormat=X: {0:F3}}"/>
                            <TextBlock Text="{Binding PunchY, StringFormat=Y: {0:F3}}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="2. 记录相机" FontSize="16" Height="40" Margin="5" Command="{Binding MarkCameraPositionCommand}"/>
                        <CheckBox Grid.Column="1" Content="视觉辅助" VerticalAlignment="Center" HorizontalAlignment="Center" IsChecked="{Binding EnableVisionAssist}"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding CameraX, StringFormat=X: {0:F3}}"/>
                            <TextBlock Text="{Binding CameraY, StringFormat=Y: {0:F3}}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="3. 计算并应用 Offset" FontSize="18" FontWeight="Bold" Height="45" Margin="5" Background="#8EB933" Command="{Binding CalculateAndSaveOffsetCommand}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding OffsetX, StringFormat=dX: {0:F3}}" FontWeight="Bold" Foreground="Red" FontSize="16"/>
                            <TextBlock Text="{Binding OffsetY, StringFormat=dY: {0:F3}}" FontWeight="Bold" Foreground="Red" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Grid Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <Border x:Name="LiveVideo" BorderBrush="Gray" BorderThickness="1" Background="#EAEAEA">
                <uc:CameraViewerControl ImageMat="{Binding CameraPreviewMat}" />
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="-" Width="60" Height="60" Background="#E0FFFF" Command="{Binding ChangeSizeCommand}" CommandParameter="Canvas-"/>
                <StackPanel VerticalAlignment="Center" Margin="10,0">
                    <TextBox Text="{Binding CanvasSize}" Width="60" FontSize="18" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="画面大小" HorizontalAlignment="Center"/>
                </StackPanel>
                <Button Content="+" Width="60" Height="60" Background="#E0FFFF" Margin="0,0,20,0" Command="{Binding ChangeSizeCommand}" CommandParameter="Canvas+"/>

                <Button Content="-" Width="60" Height="60" Background="#FFA07A" Command="{Binding ChangeSizeCommand}" CommandParameter="Ring-"/>
                <StackPanel VerticalAlignment="Center" Margin="10,0">
                    <TextBox Text="{Binding RingSize}" Width="60" FontSize="18" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="圈大小：" HorizontalAlignment="Center"/>
                </StackPanel>
                <Button Content="+" Width="60" Height="60" Background="#FFA07A" Command="{Binding ChangeSizeCommand}" CommandParameter="Ring+"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>