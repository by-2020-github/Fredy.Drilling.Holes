<Window x:Class="Fredy.Drilling.Holes.Views.NinePointCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"        xmlns:uc="clr-namespace:Fredy.Drilling.Holes.UserControls"        mc:Ignorable="d"
        Title="九点标定" Height="760" Width="1100" MaxHeight="1024" MaxWidth="1280" Background="{StaticResource Brush.Background.Subtle}"
        d:DataContext="{d:DesignInstance Type=vm:NinePointCalibrationViewModel, IsDesignTimeCreatable=False}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="410"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" Margin="0,0,10,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Header="手动输入" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="126"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="X 像素尺寸(μm)" VerticalAlignment="Center"/>
                        <hc:NumericUpDown Grid.Column="1" Value="{Binding ManualPixelSizeX, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="8,0,0,8"/>
                        <TextBlock Grid.Row="1" Text="Y 像素尺寸(μm)" VerticalAlignment="Center"/>
                        <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding ManualPixelSizeY, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="8,0,0,8"/>
                        <Button Grid.Row="2" Grid.Column="1" Width="120" Height="34" HorizontalAlignment="Left" Content="应用手动值" Command="{Binding ApplyManualCommand}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="现场九点标定" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="126"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="X 步距(mm)" VerticalAlignment="Center"/>
                        <hc:NumericUpDown Grid.Column="1" Value="{Binding XStep, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="8,0,0,8"/>

                        <TextBlock Grid.Row="1" Text="Y 步距(mm)" VerticalAlignment="Center"/>
                        <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding YStep, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="8,0,0,8"/>

                        <TextBlock Grid.Row="2" Text="模板路径" VerticalAlignment="Center"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="8,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="84"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding TemplatePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="浏览" Command="{Binding BrowseTemplateCommand}"/>
                        </Grid>

                        <TextBlock Grid.Row="3" Text="匹配阈值" VerticalAlignment="Center"/>
                        <hc:NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding MinScore, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="8,0,0,0"/>

                        <UniformGrid Grid.Row="4" Grid.ColumnSpan="2" Columns="2" Margin="0,14,0,0">
                            <Button Height="38" Margin="0,0,6,0" Content="开始九点标定" Command="{Binding StartFieldCalibrationCommand}"/>
                            <Button Height="38" Margin="6,0,0,0" Content="虚拟测试" Command="{Binding StartVirtualDemoCommand}"/>
                        </UniformGrid>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="位置调整" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Margin="0,0,6,0" Padding="8" CornerRadius="4" Background="{StaticResource Brush.Background.Subtle}">
                                <StackPanel>
                                    <TextBlock Text="当前 X" Foreground="{StaticResource Brush.Foreground.Secondary}"/>
                                    <TextBlock Text="{Binding CurrentX, StringFormat=F3}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Margin="6,0" Padding="8" CornerRadius="4" Background="{StaticResource Brush.Background.Subtle}">
                                <StackPanel>
                                    <TextBlock Text="当前 Y" Foreground="{StaticResource Brush.Foreground.Secondary}"/>
                                    <TextBlock Text="{Binding CurrentY, StringFormat=F3}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Margin="6,0,0,0" Padding="8" CornerRadius="4" Background="{StaticResource Brush.Background.Subtle}">
                                <StackPanel>
                                    <TextBlock Text="当前 Z" Foreground="{StaticResource Brush.Foreground.Secondary}"/>
                                    <TextBlock Text="{Binding CurrentZ, StringFormat=F3}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="126"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="相对步长(mm)" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Column="1" Value="{Binding RelativeMoveStep, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="X 轴" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Margin="8,0,6,8" Content="负向" Command="{Binding MoveRelativeCommand}" CommandParameter="X-"/>
                            <Button Grid.Column="2" Margin="6,0,0,8" Content="正向" Command="{Binding MoveRelativeCommand}" CommandParameter="X+"/>

                            <TextBlock Grid.Row="1" Text="Y 轴" VerticalAlignment="Center"/>
                            <Button Grid.Row="1" Grid.Column="1" Margin="8,0,6,8" Content="负向" Command="{Binding MoveRelativeCommand}" CommandParameter="Y-"/>
                            <Button Grid.Row="1" Grid.Column="2" Margin="6,0,0,8" Content="正向" Command="{Binding MoveRelativeCommand}" CommandParameter="Y+"/>

                            <TextBlock Grid.Row="2" Text="Z 轴" VerticalAlignment="Center"/>
                            <Button Grid.Row="2" Grid.Column="1" Margin="8,0,6,0" Content="负向" Command="{Binding MoveRelativeCommand}" CommandParameter="Z-"/>
                            <Button Grid.Row="2" Grid.Column="2" Margin="6,0,0,0" Content="正向" Command="{Binding MoveRelativeCommand}" CommandParameter="Z+"/>
                        </Grid>

                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="88"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="X" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Column="1" Margin="8,0,8,8" Value="{Binding AbsoluteTargetX, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}"/>
                            <Button Grid.Column="2" Margin="0,0,0,8" Content="移动到 X" Command="{Binding MoveAbsoluteCommand}" CommandParameter="X"/>

                            <TextBlock Grid.Row="1" Text="Y" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Margin="8,0,8,8" Value="{Binding AbsoluteTargetY, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}"/>
                            <Button Grid.Row="1" Grid.Column="2" Margin="0,0,0,8" Content="移动到 Y" Command="{Binding MoveAbsoluteCommand}" CommandParameter="Y"/>

                            <TextBlock Grid.Row="2" Text="Z" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Margin="8,0,8,8" Value="{Binding AbsoluteTargetZ, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumericDoubleUpDownStyle}"/>
                            <Button Grid.Row="2" Grid.Column="2" Margin="0,0,0,8" Content="移动到 Z" Command="{Binding MoveAbsoluteCommand}" CommandParameter="Z"/>

                            <Button Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Height="34" HorizontalAlignment="Left" Width="120" Content="刷新坐标" Command="{Binding RefreshPositionCommand}"/>
                        </Grid>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="3" Header="结果" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
                        <UniformGrid Grid.Row="1" Columns="2" Margin="0,12,0,0">
                            <Button Height="34" Margin="0,0,6,0" Content="应用结果" Command="{Binding ConfirmApplyCommand}"/>
                            <Button Height="34" Margin="6,0,0,0" Content="取消" Command="{Binding CancelCommand}"/>
                        </UniformGrid>
                    </Grid>
                </GroupBox>
            </Grid>
        </ScrollViewer>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource Brush.Surface.DarkAlt}" BorderBrush="{StaticResource Brush.Border.Dark}" BorderThickness="1" CornerRadius="4">
                <uc:CameraViewerControl ImageSource="{Binding PreviewImage}" />
            </Border>

            <GroupBox Grid.Row="1" Header="九点采集结果" Margin="0,10,0,0">
                <DataGrid ItemsSource="{Binding Points}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                        <DataGridTextColumn Header="StageX" Binding="{Binding StageX, StringFormat=F3}" Width="*"/>
                        <DataGridTextColumn Header="StageY" Binding="{Binding StageY, StringFormat=F3}" Width="*"/>
                        <DataGridTextColumn Header="PixelX" Binding="{Binding PixelX, StringFormat=F2}" Width="*"/>
                        <DataGridTextColumn Header="PixelY" Binding="{Binding PixelY, StringFormat=F2}" Width="*"/>
                        <DataGridTextColumn Header="Score" Binding="{Binding Score, StringFormat=F3}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>




