<Window x:Class="Fredy.Drilling.Holes.Views.NinePointCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"        xmlns:uc="clr-namespace:Fredy.Drilling.Holes.UserControls"        mc:Ignorable="d"
        Title="九点标定" Height="760" Width="1100" Background="{StaticResource Brush.Background.Subtle}"
        d:DataContext="{d:DesignInstance Type=vm:NinePointCalibrationViewModel, IsDesignTimeCreatable=False}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <GroupBox Header="手动输入" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="X 像素尺寸(μm)" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding ManualPixelSizeX, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,6"/>
                    <TextBlock Grid.Row="1" Text="Y 像素尺寸(μm)" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ManualPixelSizeY, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,6"/>
                    <Button Grid.Row="2" Grid.ColumnSpan="2" Content="应用手动值" Height="34" Command="{Binding ApplyManualCommand}"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="现场九点标定" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="xStep(mm)" VerticalAlignment="Center"/>
                        <TextBox Width="80" Margin="6,0,16,0" Text="{Binding XStep, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="yStep(mm)" VerticalAlignment="Center"/>
                        <TextBox Width="80" Margin="6,0,0,0" Text="{Binding YStep, UpdateSourceTrigger=PropertyChanged}"/>
                    </WrapPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding TemplatePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="浏览" Command="{Binding BrowseTemplateCommand}"/>
                    </Grid>

                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="匹配阈值" VerticalAlignment="Center"/>
                        <TextBox Width="80" Margin="6,0,0,0" Text="{Binding MinScore, UpdateSourceTrigger=PropertyChanged}"/>
                    </WrapPanel>

                    <Button Content="开始九点标定" Height="38" Command="{Binding StartFieldCalibrationCommand}"/>
                    <Button Content="虚拟测试(自动三角模板)" Height="34" Margin="0,8,0,0" Command="{Binding StartVirtualDemoCommand}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="位置调整" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="当前 X" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentX, StringFormat=F3}" Margin="6,0,16,0" VerticalAlignment="Center"/>
                        <TextBlock Text="当前 Y" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentY, StringFormat=F3}" Margin="6,0,16,0" VerticalAlignment="Center"/>
                        <TextBlock Text="当前 Z" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentZ, StringFormat=F3}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </WrapPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="相对步长(mm)" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Width="80" Text="{Binding RelativeMoveStep, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="X 轴" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <UniformGrid Grid.Row="0" Grid.Column="2" Columns="2" Margin="48,0,0,6">
                            <Button Content="负向" Margin="0,0,6,0" Command="{Binding MoveRelativeCommand}" CommandParameter="X-"/>
                            <Button Content="正向" Command="{Binding MoveRelativeCommand}" CommandParameter="X+"/>
                        </UniformGrid>

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Y 轴" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <UniformGrid Grid.Row="1" Grid.Column="2" Columns="2" Margin="48,0,0,6">
                            <Button Content="负向" Margin="0,0,6,0" Command="{Binding MoveRelativeCommand}" CommandParameter="Y-"/>
                            <Button Content="正向" Command="{Binding MoveRelativeCommand}" CommandParameter="Y+"/>
                        </UniformGrid>

                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Z 轴" VerticalAlignment="Center"/>
                        <UniformGrid Grid.Row="2" Grid.Column="2" Columns="2" Margin="48,0,0,0">
                            <Button Content="负向" Margin="0,0,6,0" Command="{Binding MoveRelativeCommand}" CommandParameter="Z-"/>
                            <Button Content="正向" Command="{Binding MoveRelativeCommand}" CommandParameter="Z+"/>
                        </UniformGrid>
                    </Grid>

                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="绝对 X" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Margin="6,0,12,0" Text="{Binding AbsoluteTargetX, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="2" Text="绝对 Y" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="3" Margin="6,0,12,0" Text="{Binding AbsoluteTargetY, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="4" Text="绝对 Z" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="5" Margin="6,0,0,0" Text="{Binding AbsoluteTargetZ, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <WrapPanel>
                        <Button Content="移动到 X" Width="90" Command="{Binding MoveAbsoluteCommand}" CommandParameter="X"/>
                        <Button Content="移动到 Y" Width="90" Margin="8,0,0,0" Command="{Binding MoveAbsoluteCommand}" CommandParameter="Y"/>
                        <Button Content="移动到 Z" Width="90" Margin="8,0,0,0" Command="{Binding MoveAbsoluteCommand}" CommandParameter="Z"/>
                        <Button Content="刷新坐标" Width="90" Margin="8,0,0,0" Command="{Binding RefreshPositionCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="结果" Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
                    <WrapPanel Margin="0,8,0,0">
                        <Button Content="应用结果" Width="100" Margin="0,0,8,0" Command="{Binding ConfirmApplyCommand}"/>
                        <Button Content="取消" Width="80" Command="{Binding CancelCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource Brush.Surface.DarkAlt}" BorderBrush="{StaticResource Brush.Border.Dark}" BorderThickness="1" CornerRadius="4">
                <uc:CameraViewerControl ImageSource="{Binding PreviewImage}" />
            </Border>

            <GroupBox Grid.Row="1" Header="九点采集结果" Margin="0,10,0,0">
                <DataGrid ItemsSource="{Binding Points}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                        <DataGridTextColumn Header="StageX" Binding="{Binding StageX, StringFormat=F3}" Width="*"/>
                        <DataGridTextColumn Header="StageY" Binding="{Binding StageY, StringFormat=F3}" Width="*"/>
                        <DataGridTextColumn Header="PixelX" Binding="{Binding PixelX, StringFormat=F2}" Width="*"/>
                        <DataGridTextColumn Header="PixelY" Binding="{Binding PixelY, StringFormat=F2}" Width="*"/>
                        <DataGridTextColumn Header="Score" Binding="{Binding Score, StringFormat=F3}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>




