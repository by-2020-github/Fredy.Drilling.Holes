<Window x:Class="Fredy.Drilling.Holes.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
        xmlns:models="clr-namespace:Fredy.Drilling.Holes.Models" xmlns:views="clr-namespace:Fredy.Drilling.Holes.Views" xmlns:usercontrols="clr-namespace:Fredy.Drilling.Holes.UserControls"
        mc:Ignorable="d" x:Name="thisWin"
        MaxHeight="1024" MaxWidth="1280"
        Title="参数配置" Height="750" Width="1200" Background="{StaticResource Brush.Background.Subtle}"
        d:DataContext="{d:DesignInstance Type=vm:ConfigViewModel, IsDesignTimeCreatable=False}">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0">
           
            <TabItem Header="运动控制卡">
                <TabControl Margin="10">

                    <TabItem Header="运动卡调试">
                        <usercontrols:MotionDebugControl></usercontrols:MotionDebugControl>
                    </TabItem>

                    <TabItem Header="控制器参数">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <GroupBox Header="运动控制卡" Background="{StaticResource Brush.Status.Blue.Subtle}" Margin="0,0,0,10" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="控制卡类型" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding MotionControllerTypes}"
                                                  SelectedItem="{Binding MotionController.ControllerType}"
                                                  Margin="5,0,15,0"/>
                                        <TextBlock Grid.Column="2" Text="连接字符串" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="3"
                                                  ItemsSource="{Binding MotionConnectionOptions}"
                                                  Text="{Binding MotionController.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="True"
                                                  Margin="5,0,0,0"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="轴参数配置" Background="{StaticResource Brush.Status.Blue.Subtle}" Padding="10">
                                    <StackPanel>
                                        <usercontrols:AxisParamEditorControl Header="X轴参数" AxisConfig="{Binding XAxis}"/>
                                        <usercontrols:AxisParamEditorControl Header="Y轴参数" AxisConfig="{Binding YAxis}"/>
                                        <usercontrols:AxisParamEditorControl Header="Z轴参数" AxisConfig="{Binding ZAxis}"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="工艺参数">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,0,10,0">
                                    <GroupBox Header="Z轴工艺参数"  Margin="0,0,0,10" Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <GroupBox Header="头道参数"  Grid.Column="0" Margin="2">
                                                <StackPanel Margin="5">
                                                    <TextBlock Text="初速度 (mm/s)"/>
                                                    <hc:NumericUpDown Value="{Binding FirstPass.StartSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="驱动速度 (mm/s)"/>
                                                    <hc:NumericUpDown Value="{Binding FirstPass.DriveSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="加速度 (mm/s²)"/>
                                                    <hc:NumericUpDown Value="{Binding FirstPass.Acceleration}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="延时 (ms)"/>
                                                    <hc:NumericUpDown Value="{Binding FirstPass.Delay}" Style="{StaticResource NumericIntUpDownStyle}" Margin="0,2,0,5"/>
                                                </StackPanel>
                                            </GroupBox>
                                            <GroupBox Header="二道参数"  Grid.Column="1" Margin="2">
                                                <StackPanel Margin="5">
                                                    <TextBlock Text="初速度 (mm/s)"/>
                                                    <hc:NumericUpDown Value="{Binding SecondPass.StartSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="驱动速度 (mm/s)"/>
                                                    <hc:NumericUpDown Value="{Binding SecondPass.DriveSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="加速度 (mm/s²)"/>
                                                    <hc:NumericUpDown Value="{Binding SecondPass.Acceleration}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="延时 (ms)"/>
                                                    <hc:NumericUpDown Value="{Binding SecondPass.Delay}" Style="{StaticResource NumericIntUpDownStyle}" Margin="0,2,0,5"/>
                                                </StackPanel>
                                            </GroupBox>
                                            <GroupBox Header="探测参数"  Grid.Column="2" Margin="2">
                                                <StackPanel Margin="5">
                                                    <TextBlock Text="快速移动位置 (mm)"/>
                                                    <hc:NumericUpDown Value="{Binding FastMovePos}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="快速速度 (mm/s)"/>
                                                    <hc:NumericUpDown Value="{Binding FastMoveSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="慢速移动距离 (mm)"/>
                                                    <hc:NumericUpDown Value="{Binding SlowMoveDist}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                    <TextBlock Text="慢速速度 (mm/s)"/>
                                                    <hc:NumericUpDown Value="{Binding SlowMoveSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,2,0,5"/>
                                                </StackPanel>
                                            </GroupBox>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="回零参数" Background="{StaticResource Brush.Status.Blue.Subtle}" Padding="10">
                                        <StackPanel>
                                            <GroupBox Header="回零模式" >
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <CheckBox Content="IO回零" IsChecked="{Binding IsIoHome}"  Margin="15,0"/>
                                                    <CheckBox Content="锁存" IsChecked="{Binding IsLatch}"  Margin="15,0"/>
                                                    <CheckBox Content="光栅尺回零" IsChecked="{Binding IsGratingHome}"  Margin="15,0"/>
                                                </StackPanel>
                                            </GroupBox>

                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <GroupBox Header="机械回零" Margin="0,0,5,0">
                                                    <UniformGrid Columns="2" Margin="8">
                                                        <TextBlock Text="搜索速度 (mm/s)" VerticalAlignment="Center" Margin="0,0,6,6"/>
                                                        <hc:NumericUpDown Value="{Binding HomeSearchSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,6"/>
                                                        <TextBlock Text="回零超时(ms)" VerticalAlignment="Center" Margin="0,0,6,6"/>
                                                        <hc:NumericUpDown Value="{Binding AdtHoming.HomeTimeoutMs}" Style="{StaticResource NumericIntUpDownStyle}" Margin="0,0,0,6"/>
                                                        <TextBlock Text="脱离距离 (mm)" VerticalAlignment="Center" Margin="0,0,6,6"/>
                                                        <hc:NumericUpDown Value="{Binding AdtHoming.HomeBackoffMm}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,6"/>
                                                        <TextBlock Text="初速度 (mm/s)" VerticalAlignment="Center" Margin="0,0,6,6"/>
                                                        <hc:NumericUpDown Value="{Binding AdtHoming.SlowHomeStartSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,6"/>
                                                        <TextBlock Text="速度 (mm/s)" VerticalAlignment="Center" Margin="0,0,6,6"/>
                                                        <hc:NumericUpDown Value="{Binding AdtHoming.SlowHomeSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,6"/>
                                                        <TextBlock Text="加速度 (mm/s²)" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <hc:NumericUpDown Value="{Binding AdtHoming.SlowHomeAcceleration}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0"/>
                                                    </UniformGrid>
                                                </GroupBox>

                                                <GroupBox Grid.Column="1" Header="光栅/锁存回零" Margin="5,0,5,0">
                                                    <UniformGrid Columns="2" Margin="8">
                                                        <TextBlock Text="初速度 (mm/s)" VerticalAlignment="Center" Margin="0,0,6,6"/>
                                                        <hc:NumericUpDown Value="{Binding AdtHoming.GratingHomeStartSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,6"/>
                                                        <TextBlock Text="速度 (mm/s)" VerticalAlignment="Center" Margin="0,0,6,6"/>
                                                        <hc:NumericUpDown Value="{Binding AdtHoming.GratingHomeSpeed}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,6"/>
                                                        <TextBlock Text="加速度 (mm/s²)" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <hc:NumericUpDown Value="{Binding AdtHoming.GratingHomeAcceleration}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0"/>
                                                    </UniformGrid>
                                                </GroupBox>

                                                <GroupBox Grid.Column="2" Header="Z轴专项" Margin="5,0,0,0">
                                                    <StackPanel Margin="8">
                                                        <UniformGrid Columns="2">
                                                            <TextBlock Text="抬起距离 (mm)" VerticalAlignment="Center" Margin="0,0,6,6"/>
                                                            <hc:NumericUpDown Value="{Binding AdtHoming.ZHomeLiftMm}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="0,0,0,6"/>
                                                        </UniformGrid>
                                                        <CheckBox Content="Z机械回零朝正方向搜索"
                                                                  IsChecked="{Binding AdtHoming.ZHomeTowardPositiveDirection}"
                                                                  Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </GroupBox>
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>

                            <GroupBox Grid.Column="1" Header="端口配置" Background="{StaticResource Brush.Status.Yellow.Subtle}" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <GroupBox Header="输入端口" BorderBrush="{StaticResource Brush.Border.Strong}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="X机械零位" VerticalAlignment="Center"/>
                                                <hc:NumericUpDown Grid.Column="1" Value="{Binding XLimitPort.PortIndex}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0"/>
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding XLimitPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox Grid.Column="3" Content="安装负方向" IsChecked="{Binding XLimitPort.IsNegative}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Y机械零位" VerticalAlignment="Center"/>
                                                <hc:NumericUpDown Grid.Column="1" Value="{Binding YLimitPort.PortIndex}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0"/>
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding YLimitPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox Grid.Column="3" Content="安装负方向" IsChecked="{Binding YLimitPort.IsNegative}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Z机械零位" VerticalAlignment="Center"/>
                                                <hc:NumericUpDown Grid.Column="1" Value="{Binding AdtHoming.ZLimitPort.PortIndex}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0"/>
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding AdtHoming.ZLimitPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox Grid.Column="3" Content="安装负方向" IsChecked="{Binding AdtHoming.ZLimitPort.IsNegative}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="X光栅零位" VerticalAlignment="Center"/>
                                                <hc:NumericUpDown Grid.Column="1" Value="{Binding AdtHoming.XGratingPort.PortIndex}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0"/>
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding AdtHoming.XGratingPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox Grid.Column="3" Content="安装负方向" IsChecked="{Binding AdtHoming.XGratingPort.IsNegative}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Y光栅零位" VerticalAlignment="Center"/>
                                                <hc:NumericUpDown Grid.Column="1" Value="{Binding AdtHoming.YGratingPort.PortIndex}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0"/>
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding AdtHoming.YGratingPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox Grid.Column="3" Content="安装负方向" IsChecked="{Binding AdtHoming.YGratingPort.IsNegative}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Grid.Row="1" Header="输出端口" BorderBrush="{StaticResource Brush.Border.Strong}">
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="红灯" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Column="1" Value="{Binding RedLightPort}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,2"/>
                                            <TextBlock Grid.Row="1" Text="绿灯" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="0" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,2"/>
                                            <TextBlock Grid.Row="2" Text="黄灯" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Value="0" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,2"/>
                                            <TextBlock Grid.Row="3" Text="蜂鸣器" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Row="3" Grid.Column="1" Value="0" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,2"/>
                                        </Grid>
                                    </GroupBox>

                                    <StackPanel Grid.Row="3" Margin="0,10,0,0">
                                        <CheckBox Content="调试模式" IsChecked="{Binding IsDebugMode}" Margin="0,5"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </TabItem>

      
                </TabControl>
            </TabItem>



            <TabItem Header="相机">
                <TabControl>

                    <TabItem Header="相机参数">
                         <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="相机基础配置" Background="{StaticResource Brush.Status.Blue.Subtle}" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="相机类型" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding CameraTypes}"
                                          SelectedItem="{Binding Camera.CameraType}"
                                          Margin="5,0,15,0"/>
                                <TextBlock Grid.Column="2" Text="连接字符串" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="3"
                                          ItemsSource="{Binding CameraConnectionOptions}"
                                          Text="{Binding Camera.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          Margin="5,0,0,0"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="像素尺寸" Background="{StaticResource Brush.Status.Green.Subtle}" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="像素尺寸 X (μm)" VerticalAlignment="Center"/>
                                    <hc:NumericUpDown Grid.Column="1" Value="{Binding Camera.PixelSizeX}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="5,0,15,0"/>
                                    <TextBlock Grid.Column="2" Text="像素尺寸 Y (μm)" VerticalAlignment="Center"/>
                                    <hc:NumericUpDown Grid.Column="3" Value="{Binding Camera.PixelSizeY}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="5,0,0,0"/>
                                </Grid>

                                <Button Margin="0,10,0,0"
                                        Height="34"
                                        Width="140"
                                        HorizontalAlignment="Left"
                                        Content="打开九点标定"
                                        Click="OpenNinePointCalibrationButton_Click"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="视野尺寸" Background="{StaticResource Brush.Status.Yellow.Subtle}" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="视野宽度 (像素)" VerticalAlignment="Center"/>
                                <hc:NumericUpDown Grid.Column="1" Value="{Binding Camera.FovWidth}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0,15,0"/>
                                <TextBlock Grid.Column="2" Text="视野高度 (像素)" VerticalAlignment="Center"/>
                                <hc:NumericUpDown Grid.Column="3" Value="{Binding Camera.FovHeight}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0,0,0"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="分区扫描检测参数" Background="{StaticResource Brush.Status.Blue.Subtle}" Padding="10" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="32"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                                          Content="使用明场检测"
                                          IsChecked="{Binding ScanUseBrightFieldDetector}"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Text="最小面积" VerticalAlignment="Center"/>
                                <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding ScanDetectMinArea}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0,15,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="最大面积" VerticalAlignment="Center"/>
                                <hc:NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding ScanDetectMaxArea}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0,0,0"/>

                                <TextBlock Grid.Row="2" Text="阈值" VerticalAlignment="Center"/>
                                <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding ScanDetectThreshold}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0,15,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="圆度(0~1)" VerticalAlignment="Center"/>
                                <hc:NumericUpDown Grid.Row="2" Grid.Column="3" Value="{Binding ScanDetectCircularity}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="5,0,0,0"/>

                                <TextBlock Grid.Row="3" Text="形态学核大小" VerticalAlignment="Center"/>
                                <hc:NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding ScanDetectMorphologySize}" Style="{StaticResource NumericIntUpDownStyle}" Margin="5,0,15,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="去重容差(mm)" VerticalAlignment="Center"/>
                                <hc:NumericUpDown Grid.Row="3" Grid.Column="3" Value="{Binding ScanDeduplicateToleranceMm}" Style="{StaticResource NumericDoubleUpDownStyle}" Margin="5,0,0,0"/>

                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
                    
                    </TabItem>
                       
                    <TabItem Header="相机调试">
                        <views:HkCameraControl></views:HkCameraControl>
                    </TabItem>

                </TabControl>
              
            </TabItem>

            <TabItem Header="一道探测参数">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="0 代表本圈不探测，其他数字 N 代表本圈探测次数"
                               Foreground="{StaticResource Brush.Status.Green}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"
                               FontSize="14"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding DetectionRingItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DetectionRingItem}">
                                    <Grid Margin="45,2" Height="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Index, StringFormat=第{0}圈}" VerticalAlignment="Center" FontSize="14"/>
                                        <hc:NumericUpDown Grid.Column="1"
                                                          Value="{Binding DetectionCount, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource NumericIntUpDownStyle}"
                                                          Margin="0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,12">
                        <TextBlock Text="探测偏移量阈值：" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                        <hc:NumericUpDown Value="{Binding DetectionOffsetThreshold, UpdateSourceTrigger=PropertyChanged}" Width="160" Height="28" Style="{StaticResource NumericIntUpDownStyle}" Margin="0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="重置"
                                Width="110"
                                Height="34"
                                Command="{Binding ResetDetectionCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="二道探测参数">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="0 代表本圈不探测，其他数字 N 代表本圈探测次数"
                               Foreground="{StaticResource Brush.Status.Green}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"
                               FontSize="14"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding SecondPassDetectionItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SecondPassDetectionItem}">
                                    <Grid Margin="45,2" Height="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Index, StringFormat=第{0}圈}" VerticalAlignment="Center" FontSize="14"/>
                                        <hc:NumericUpDown Grid.Column="1"
                                                          Value="{Binding DetectionCount, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource NumericIntUpDownStyle}"
                                                          Margin="0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,12">
                        <TextBlock Text="探测偏移量阈值：" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                        <hc:NumericUpDown Value="{Binding SecondPassOffsetThreshold, UpdateSourceTrigger=PropertyChanged}" Width="160" Height="28" Style="{StaticResource NumericIntUpDownStyle}" Margin="0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="重置"
                                Width="110"
                                Height="34"
                                Command="{Binding ResetSecondPassDetectionCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Column="1"
                Margin="10,0,0,0"
                Padding="12"
                Background="{StaticResource Brush.Background}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="全局操作"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <Button Height="38"
                        Margin="0,0,0,8"
                        Background="{StaticResource Brush.Status.Green}"
                        FontWeight="Bold"
                        Content="保存"
                        Command="{Binding SaveConfigCommand}"/>

                <Button Height="38"
                        Margin="0,0,0,8"
                        Content="取消"
                        Command="{Binding CancelChangesCommand}"/>

                <Button Height="38"
                        Margin="0,0,0,12"
                        Content="保存并关闭"
                        Command="{Binding ApplyAndCloseCommand}"
                        CommandParameter="{Binding ElementName=thisWin}"/>

                <Separator Margin="0,0,0,10"/>

                <TextBlock Text="已修改参数"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{Binding ModifiedParametersInfo}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource Brush.Foreground.Secondary}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
