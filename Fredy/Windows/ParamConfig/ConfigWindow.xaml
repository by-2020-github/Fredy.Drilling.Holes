<Window
    x:Class="Fredy.Drilling.Holes.Views.ConfigWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Fredy.Drilling.Holes.Models"
    xmlns:usercontrols="clr-namespace:Fredy.Drilling.Holes.UserControls"
    xmlns:views="clr-namespace:Fredy.Drilling.Holes.Views"
    xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
    x:Name="thisWin"
    Title="参数配置"
    Width="1200"
    Height="750"
    MaxWidth="1280"
    MaxHeight="1024"
    d:DataContext="{d:DesignInstance Type=vm:ConfigViewModel,
                                     IsDesignTimeCreatable=False}"
    Background="{StaticResource Brush.Background.Subtle}"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0">

            <TabItem Header="运动控制卡">
                <TabControl Margin="10">

                    <TabItem Header="运动卡调试">
                        <usercontrols:MotionDebugControl />
                    </TabItem>

                    <TabItem Header="控制器参数">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <GroupBox
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    Background="{StaticResource Brush.Status.Blue.Subtle}"
                                    Header="运动控制卡">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="控制卡类型" />
                                        <ComboBox
                                            Grid.Column="1"
                                            Margin="5,0,15,0"
                                            ItemsSource="{Binding MotionControllerTypes}"
                                            SelectedItem="{Binding MotionController.ControllerType}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Text="连接字符串" />
                                        <ComboBox
                                            Grid.Column="3"
                                            Margin="5,0,0,0"
                                            IsEditable="True"
                                            ItemsSource="{Binding MotionConnectionOptions}"
                                            Text="{Binding MotionController.ConnectionString, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox
                                    Padding="10"
                                    Background="{StaticResource Brush.Status.Blue.Subtle}"
                                    Header="轴参数配置">
                                    <StackPanel>
                                        <usercontrols:AxisParamEditorControl AxisConfig="{Binding XAxis}" Header="X轴参数" />
                                        <usercontrols:AxisParamEditorControl AxisConfig="{Binding YAxis}" Header="Y轴参数" />
                                        <usercontrols:AxisParamEditorControl AxisConfig="{Binding ZAxis}" Header="Z轴参数" />
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="工艺参数">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="320" />
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,0,10,0">
                                    <GroupBox
                                        Margin="0,0,0,10"
                                        Padding="10"
                                        Header="Z轴工艺参数">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <GroupBox
                                                Grid.Column="0"
                                                Margin="2"
                                                Header="头道参数">
                                                <StackPanel Margin="5">
                                                    <TextBlock Text="初速度 (mm/s)" />
                                                    <hc:NumericUpDown
                                                        Margin="0,2,0,5"
                                                        Style="{StaticResource NumericDoubleUpDownStyle}"
                                                        Value="{Binding FirstPass.StartSpeed}" />
                                                    <TextBlock Text="驱动速度 (mm/s)" />
                                                    <hc:NumericUpDown
                                                        Margin="0,2,0,5"
                                                        Style="{StaticResource NumericDoubleUpDownStyle}"
                                                        Value="{Binding FirstPass.DriveSpeed}" />
                                                    <TextBlock Text="加速度 (mm/s²)" />
                                                    <hc:NumericUpDown
                                                        Margin="0,2,0,5"
                                                        Style="{StaticResource NumericDoubleUpDownStyle}"
                                                        Value="{Binding FirstPass.Acceleration}" />
                                                    <TextBlock Text="延时 (ms)" />
                                                    <hc:NumericUpDown
                                                        Margin="0,2,0,5"
                                                        Style="{StaticResource NumericIntUpDownStyle}"
                                                        Value="{Binding FirstPass.Delay}" />
                                                </StackPanel>
                                            </GroupBox>
                                            <GroupBox
                                                Grid.Column="1"
                                                Margin="2"
                                                Header="二道参数">
                                                <StackPanel Margin="5">
                                                    <TextBlock Text="初速度 (mm/s)" />
                                                    <hc:NumericUpDown
                                                        Margin="0,2,0,5"
                                                        Style="{StaticResource NumericDoubleUpDownStyle}"
                                                        Value="{Binding SecondPass.StartSpeed}" />
                                                    <TextBlock Text="驱动速度 (mm/s)" />
                                                    <hc:NumericUpDown
                                                        Margin="0,2,0,5"
                                                        Style="{StaticResource NumericDoubleUpDownStyle}"
                                                        Value="{Binding SecondPass.DriveSpeed}" />
                                                    <TextBlock Text="加速度 (mm/s²)" />
                                                    <hc:NumericUpDown
                                                        Margin="0,2,0,5"
                                                        Style="{StaticResource NumericDoubleUpDownStyle}"
                                                        Value="{Binding SecondPass.Acceleration}" />
                                                    <TextBlock Text="延时 (ms)" />
                                                    <hc:NumericUpDown
                                                        Margin="0,2,0,5"
                                                        Style="{StaticResource NumericIntUpDownStyle}"
                                                        Value="{Binding SecondPass.Delay}" />
                                                </StackPanel>
                                            </GroupBox>
                                            <GroupBox
                                                Grid.Column="2"
                                                Margin="2"
                                                Header="探测参数入口">
                                                <TextBlock
                                                    Margin="8"
                                                    Text="表面探测相关的全局参数已统一移动到“冲孔表面探测”页签，包含快速段、慢速搜索段、安全位和探测方式。"
                                                    TextWrapping="Wrap" />
                                            </GroupBox>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox
                                        Padding="10"
                                        Background="{StaticResource Brush.Status.Blue.Subtle}"
                                        Header="回零参数">
                                        <StackPanel>
                                            <GroupBox Header="回零模式">
                                                <StackPanel Margin="5" Orientation="Horizontal">
                                                    <CheckBox
                                                        Margin="15,0"
                                                        Content="IO回零"
                                                        IsChecked="{Binding IsIoHome}" />
                                                    <CheckBox
                                                        Margin="15,0"
                                                        Content="锁存"
                                                        IsChecked="{Binding IsLatch}" />
                                                    <CheckBox
                                                        Margin="15,0"
                                                        Content="光栅尺回零"
                                                        IsChecked="{Binding IsGratingHome}" />
                                                </StackPanel>
                                            </GroupBox>

                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <GroupBox Margin="0,0,5,0" Header="机械回零默认值">
                                                    <StackPanel Margin="8">
                                                        <TextBlock
                                                            Margin="0,0,0,8"
                                                            Text="快速寻零、慢速寻零和回零超时已迁移到各轴参数中统一配置。"
                                                            TextWrapping="Wrap" />
                                                        <UniformGrid Columns="2">
                                                            <TextBlock
                                                                Margin="0,0,6,6"
                                                                VerticalAlignment="Center"
                                                                Text="脱离距离 (mm)" />
                                                            <hc:NumericUpDown
                                                                Margin="0,0,0,6"
                                                                Style="{StaticResource NumericDoubleUpDownStyle}"
                                                                Value="{Binding AdtHoming.HomeBackoffMm}" />
                                                            <TextBlock
                                                                Margin="0,0,6,6"
                                                                VerticalAlignment="Center"
                                                                Text="默认慢速初速度 (mm/s)" />
                                                            <hc:NumericUpDown
                                                                Margin="0,0,0,6"
                                                                Style="{StaticResource NumericDoubleUpDownStyle}"
                                                                Value="{Binding AdtHoming.SlowHomeStartSpeed}" />
                                                            <TextBlock
                                                                Margin="0,0,6,0"
                                                                VerticalAlignment="Center"
                                                                Text="加速度 (mm/s²)" />
                                                            <hc:NumericUpDown
                                                                Margin="0"
                                                                Style="{StaticResource NumericDoubleUpDownStyle}"
                                                                Value="{Binding AdtHoming.SlowHomeAcceleration}" />
                                                        </UniformGrid>
                                                    </StackPanel>
                                                </GroupBox>

                                                <GroupBox
                                                    Grid.Column="1"
                                                    Margin="5,0,5,0"
                                                    Header="光栅/锁存回零">
                                                    <UniformGrid Margin="8" Columns="2">
                                                        <TextBlock
                                                            Margin="0,0,6,6"
                                                            VerticalAlignment="Center"
                                                            Text="初速度 (mm/s)" />
                                                        <hc:NumericUpDown
                                                            Margin="0,0,0,6"
                                                            Style="{StaticResource NumericDoubleUpDownStyle}"
                                                            Value="{Binding AdtHoming.GratingHomeStartSpeed}" />
                                                        <TextBlock
                                                            Margin="0,0,6,6"
                                                            VerticalAlignment="Center"
                                                            Text="速度 (mm/s)" />
                                                        <hc:NumericUpDown
                                                            Margin="0,0,0,6"
                                                            Style="{StaticResource NumericDoubleUpDownStyle}"
                                                            Value="{Binding AdtHoming.GratingHomeSpeed}" />
                                                        <TextBlock
                                                            Margin="0,0,6,0"
                                                            VerticalAlignment="Center"
                                                            Text="加速度 (mm/s²)" />
                                                        <hc:NumericUpDown
                                                            Margin="0"
                                                            Style="{StaticResource NumericDoubleUpDownStyle}"
                                                            Value="{Binding AdtHoming.GratingHomeAcceleration}" />
                                                        <TextBlock
                                                            Margin="0,6,6,6"
                                                            VerticalAlignment="Center"
                                                            Text="预移动目标 (mm)" />
                                                        <hc:NumericUpDown
                                                            Margin="0,6,0,6"
                                                            Style="{StaticResource NumericDoubleUpDownStyle}"
                                                            Value="{Binding AdtHoming.GratingPreMoveTargetMm}" />
                                                        <TextBlock
                                                            Margin="0,0,6,0"
                                                            VerticalAlignment="Center"
                                                            Text="预移动速度 (mm/s)" />
                                                        <hc:NumericUpDown
                                                            Margin="0"
                                                            Style="{StaticResource NumericDoubleUpDownStyle}"
                                                            Value="{Binding AdtHoming.GratingPreMoveSpeed}" />
                                                    </UniformGrid>
                                                </GroupBox>

                                                <GroupBox
                                                    Grid.Column="2"
                                                    Margin="5,0,0,0"
                                                    Header="Z轴专项">
                                                    <StackPanel Margin="8">
                                                        <UniformGrid Columns="2">
                                                            <TextBlock
                                                                Margin="0,0,6,6"
                                                                VerticalAlignment="Center"
                                                                Text="抬起距离 (mm)" />
                                                            <hc:NumericUpDown
                                                                Margin="0,0,0,6"
                                                                Style="{StaticResource NumericDoubleUpDownStyle}"
                                                                Value="{Binding AdtHoming.ZHomeLiftMm}" />
                                                        </UniformGrid>
                                                        <CheckBox
                                                            Margin="0,6,0,0"
                                                            Content="Z机械回零朝正方向搜索"
                                                            IsChecked="{Binding AdtHoming.ZHomeTowardPositiveDirection}" />
                                                    </StackPanel>
                                                </GroupBox>
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>

                            <GroupBox
                                Grid.Column="1"
                                Padding="10"
                                Background="{StaticResource Brush.Status.Yellow.Subtle}"
                                Header="端口配置">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <GroupBox
                                        Margin="0,0,0,10"
                                        BorderBrush="{StaticResource Brush.Border.Strong}"
                                        Header="输入端口">
                                        <StackPanel>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="X机械零位" />
                                                <hc:NumericUpDown
                                                    Grid.Column="1"
                                                    Margin="5,0"
                                                    Style="{StaticResource NumericIntUpDownStyle}"
                                                    Value="{Binding XLimitPort.PortIndex}" />
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding XLimitPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox
                                                    Grid.Column="3"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Content="安装负方向"
                                                    IsChecked="{Binding XLimitPort.IsNegative}" />
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="Y机械零位" />
                                                <hc:NumericUpDown
                                                    Grid.Column="1"
                                                    Margin="5,0"
                                                    Style="{StaticResource NumericIntUpDownStyle}"
                                                    Value="{Binding YLimitPort.PortIndex}" />
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding YLimitPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox
                                                    Grid.Column="3"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Content="安装负方向"
                                                    IsChecked="{Binding YLimitPort.IsNegative}" />
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="Z机械零位" />
                                                <hc:NumericUpDown
                                                    Grid.Column="1"
                                                    Margin="5,0"
                                                    Style="{StaticResource NumericIntUpDownStyle}"
                                                    Value="{Binding AdtHoming.ZLimitPort.PortIndex}" />
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding AdtHoming.ZLimitPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox
                                                    Grid.Column="3"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Content="安装负方向"
                                                    IsChecked="{Binding AdtHoming.ZLimitPort.IsNegative}" />
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="X光栅零位" />
                                                <hc:NumericUpDown
                                                    Grid.Column="1"
                                                    Margin="5,0"
                                                    Style="{StaticResource NumericIntUpDownStyle}"
                                                    Value="{Binding AdtHoming.XGratingPort.PortIndex}" />
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding AdtHoming.XGratingPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox
                                                    Grid.Column="3"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Content="安装负方向"
                                                    IsChecked="{Binding AdtHoming.XGratingPort.IsNegative}" />
                                            </Grid>
                                            <Grid Margin="0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="Y光栅零位" />
                                                <hc:NumericUpDown
                                                    Grid.Column="1"
                                                    Margin="5,0"
                                                    Style="{StaticResource NumericIntUpDownStyle}"
                                                    Value="{Binding AdtHoming.YGratingPort.PortIndex}" />
                                                <!--<CheckBox Grid.Column="2" Content="低电平有效" IsChecked="{Binding AdtHoming.YGratingPort.IsLowLevelActive}" VerticalAlignment="Center" Margin="8,0,0,0"/>-->
                                                <CheckBox
                                                    Grid.Column="3"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Content="安装负方向"
                                                    IsChecked="{Binding AdtHoming.YGratingPort.IsNegative}" />
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox
                                        Grid.Row="1"
                                        BorderBrush="{StaticResource Brush.Border.Strong}"
                                        Header="输出端口">
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition />
                                                <RowDefinition />
                                                <RowDefinition />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <TextBlock VerticalAlignment="Center" Text="红灯" />
                                            <hc:NumericUpDown
                                                Grid.Column="1"
                                                Margin="5,2"
                                                Style="{StaticResource NumericIntUpDownStyle}"
                                                Value="{Binding RedLightPort}" />
                                            <TextBlock
                                                Grid.Row="1"
                                                VerticalAlignment="Center"
                                                Text="绿灯" />
                                            <hc:NumericUpDown
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Margin="5,2"
                                                Style="{StaticResource NumericIntUpDownStyle}"
                                                Value="0" />
                                            <TextBlock
                                                Grid.Row="2"
                                                VerticalAlignment="Center"
                                                Text="黄灯" />
                                            <hc:NumericUpDown
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Margin="5,2"
                                                Style="{StaticResource NumericIntUpDownStyle}"
                                                Value="0" />
                                            <TextBlock
                                                Grid.Row="3"
                                                VerticalAlignment="Center"
                                                Text="蜂鸣器" />
                                            <hc:NumericUpDown
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Margin="5,2"
                                                Style="{StaticResource NumericIntUpDownStyle}"
                                                Value="0" />
                                        </Grid>
                                    </GroupBox>

                                    <StackPanel Grid.Row="3" Margin="0,10,0,0">
                                        <CheckBox
                                            Margin="0,5"
                                            Content="调试模式"
                                            IsChecked="{Binding IsDebugMode}" />
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </TabItem>


                </TabControl>
            </TabItem>



            <TabItem Header="冲孔表面探测">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="14"
                            Foreground="{StaticResource Brush.Foreground.Secondary}"
                            Text="用于自动冲孔前的表面预探、首点首刀 SurfaceZ 记录以及后续孔位补偿。"
                            TextWrapping="Wrap" />

                        <GroupBox
                            Margin="0,0,0,10"
                            Padding="10"
                            Background="{StaticResource Brush.Status.Blue.Subtle}"
                            Header="全局安全位与冲孔速度">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="当前参考 Z" />
                                <TextBox
                                    Grid.Column="1"
                                    Margin="5,0,15,8"
                                    IsReadOnly="True"
                                    IsReadOnlyCaretVisible="False"
                                    Text="{Binding CurrentReferenceZDisplay}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text="由校准页测试冲孔检测到表面后自动写回的全局参考 Z。仅显示，不在此页直接编辑；若为“未设置”，自动冲孔将缺少初始参考值。"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Text="自动冲孔 SafeZ" />
                                <hc:NumericUpDown
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="5,0,15,8"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding PunchSafeZ, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text="自动冲孔流程每次下压完成后回到的全局绝对 Z 坐标，不影响校准页测试冲孔的 SafeZ。"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="2"
                                    VerticalAlignment="Center"
                                    Text="FastToSafeZSpeed" />
                                <hc:NumericUpDown
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="5,0,15,8"
                                    Minimum="0"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding FastToSafeZSpeed, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text="快速回 SafeZ 的速度，0 表示沿用 Z 轴参数中的速度。"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="3"
                                    VerticalAlignment="Center"
                                    Text="PunchDownSpeed" />
                                <hc:NumericUpDown
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="5,0,15,0"
                                    Minimum="0"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding PunchDownSpeed, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text="正式冲孔下压速度，头道和二道均采用此参数；0 表示沿用 Z 轴参数中的速度。"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </GroupBox>

                        <GroupBox
                            Margin="0,0,0,10"
                            Padding="10"
                            Background="{StaticResource Brush.Status.Blue.Subtle}"
                            Header="快速段与慢速搜索段">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Text="快速接近距离"
                                    ToolTip="从当前 SafeZ 先快速下探的相对距离和速度。负值表示向下；这段应尽量接近表面但不要提前撞到表面。" />
                                <hc:NumericUpDown
                                    Grid.Column="1"
                                    Margin="5,0,15,8"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding FastMovePos, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Text="快速接近速度" />
                                <hc:NumericUpDown
                                    Grid.Column="3"
                                    Margin="5,0,15,8"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding FastMoveSpeed, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Column="4"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text=""
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Text="慢速搜索距离"
                                    ToolTip="慢速段结束后继续慢速下探的相对距离和速度。慢速段必须覆盖真实表面所在 Z，否则会出现“在设定搜索距离内未检测到表面信号”。" />
                                <hc:NumericUpDown
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="5,0,15,0"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding SlowMoveDist, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Text="慢速搜索速度" />
                                <hc:NumericUpDown
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Margin="5,0,15,0"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding SlowMoveSpeed, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="4"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text=""
                                    TextWrapping="Wrap" />
                            </Grid>
                        </GroupBox>

                        <GroupBox
                            Margin="0,0,0,10"
                            Padding="10"
                            Background="{StaticResource Brush.Status.Green.Subtle}"
                            Header="表面预探点(相对第一个孔位的预探偏移，默认 X=-1mm、Y=0mm。)">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center" Text="X偏移" />
                                <hc:NumericUpDown
                                    Grid.Column="1"
                                    Margin="5,0,15,0"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding SurfaceProbeOffsetX, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Text="Y偏移" />
                                <hc:NumericUpDown
                                    Grid.Column="3"
                                    Margin="5,0,15,0"
                                    Style="{StaticResource NumericDoubleUpDownStyle}"
                                    Value="{Binding SurfaceProbeOffsetY, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </GroupBox>

                        <GroupBox
                            Margin="0,0,0,10"
                            Padding="10"
                            Background="{StaticResource Brush.Status.Yellow.Subtle}"
                            Header="表面探测方式">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Text="表面探测方式" />
                                <ComboBox
                                    Grid.Column="1"
                                    Margin="5,0,15,8"
                                    ItemsSource="{Binding SurfaceDetectionModes}"
                                    SelectedItem="{Binding SurfaceDetectionMode, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text="Latch：使用运动卡锁存位置；IoPolling：运动中轮询输入端口并记录当前 Z。"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,0,0,8"
                                    VerticalAlignment="Center"
                                    Text="表面探测IO" />
                                <hc:NumericUpDown
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="5,0,15,8"
                                    DecimalPlaces="0"
                                    Increment="1"
                                    Minimum="0"
                                    Style="{StaticResource NumericIntUpDownStyle}"
                                    Value="{Binding SurfaceDetectInputPort, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,8"
                                    Content="SurfaceDetectInputLowActive：低电平有效"
                                    IsChecked="{Binding SurfaceDetectInputLowActive, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="2"
                                    VerticalAlignment="Center"
                                    Text="探测时IO轮询间隔" />
                                <hc:NumericUpDown
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="5,0,15,0"
                                    DecimalPlaces="0"
                                    Increment="1"
                                    Minimum="1"
                                    Style="{StaticResource NumericIntUpDownStyle}"
                                    Value="{Binding SurfaceDetectPollIntervalMs, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="2"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                                    Text="IO 轮询和冲孔中 SurfaceZ 采样的检查间隔，单位 ms。"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="相机">
                <TabControl>

                    <TabItem Header="相机参数">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <GroupBox
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    Background="{StaticResource Brush.Status.Blue.Subtle}"
                                    Header="相机基础配置">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="260" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="相机类型" />
                                        <ComboBox
                                            Grid.Column="1"
                                            Margin="5,0,15,0"
                                            ItemsSource="{Binding CameraTypes}"
                                            SelectedItem="{Binding Camera.CameraType}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Text="连接字符串" />
                                        <ComboBox
                                            Grid.Column="3"
                                            Margin="5,0,0,0"
                                            IsEditable="True"
                                            ItemsSource="{Binding CameraConnectionOptions}"
                                            Text="{Binding Camera.ConnectionString, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    Background="{StaticResource Brush.Status.Green.Subtle}"
                                    Header="像素尺寸">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="200" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center" Text="像素尺寸 X (μm)" />
                                            <hc:NumericUpDown
                                                Grid.Column="1"
                                                Margin="5,0,15,0"
                                                Style="{StaticResource NumericDoubleUpDownStyle}"
                                                Value="{Binding Camera.PixelSizeX}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Text="像素尺寸 Y (μm)" />
                                            <hc:NumericUpDown
                                                Grid.Column="3"
                                                Margin="5,0,0,0"
                                                Style="{StaticResource NumericDoubleUpDownStyle}"
                                                Value="{Binding Camera.PixelSizeY}" />
                                        </Grid>

                                        <Button
                                            Width="140"
                                            Height="34"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left"
                                            Click="OpenNinePointCalibrationButton_Click"
                                            Content="打开九点标定" />
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox
                                    Padding="10"
                                    Background="{StaticResource Brush.Status.Yellow.Subtle}"
                                    Header="视野尺寸">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="200" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="视野宽度 (像素)" />
                                        <hc:NumericUpDown
                                            Grid.Column="1"
                                            Margin="5,0,15,0"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding Camera.FovWidth}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Text="视野高度 (像素)" />
                                        <hc:NumericUpDown
                                            Grid.Column="3"
                                            Margin="5,0,0,0"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding Camera.FovHeight}" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox
                                    Margin="0,10,0,0"
                                    Padding="10"
                                    Background="{StaticResource Brush.Status.Blue.Subtle}"
                                    Header="分区扫描检测参数">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="32" />
                                            <RowDefinition Height="32" />
                                            <RowDefinition Height="32" />
                                            <RowDefinition Height="32" />
                                        </Grid.RowDefinitions>

                                        <CheckBox
                                            Grid.Row="0"
                                            Grid.ColumnSpan="2"
                                            VerticalAlignment="Center"
                                            Content="使用明场检测"
                                            IsChecked="{Binding ScanUseBrightFieldDetector}" />

                                        <TextBlock
                                            Grid.Row="1"
                                            VerticalAlignment="Center"
                                            Text="最小面积" />
                                        <hc:NumericUpDown
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="5,0,15,0"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding ScanDetectMinArea}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Text="最大面积" />
                                        <hc:NumericUpDown
                                            Grid.Row="1"
                                            Grid.Column="3"
                                            Margin="5,0,0,0"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding ScanDetectMaxArea}" />

                                        <TextBlock
                                            Grid.Row="2"
                                            VerticalAlignment="Center"
                                            Text="阈值" />
                                        <hc:NumericUpDown
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="5,0,15,0"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding ScanDetectThreshold}" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Text="圆度(0~1)" />
                                        <hc:NumericUpDown
                                            Grid.Row="2"
                                            Grid.Column="3"
                                            Margin="5,0,0,0"
                                            Style="{StaticResource NumericDoubleUpDownStyle}"
                                            Value="{Binding ScanDetectCircularity}" />

                                        <TextBlock
                                            Grid.Row="3"
                                            VerticalAlignment="Center"
                                            Text="形态学核大小" />
                                        <hc:NumericUpDown
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="5,0,15,0"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding ScanDetectMorphologySize}" />
                                        <TextBlock
                                            Grid.Row="3"
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Text="去重容差(mm)" />
                                        <hc:NumericUpDown
                                            Grid.Row="3"
                                            Grid.Column="3"
                                            Margin="5,0,0,0"
                                            Style="{StaticResource NumericDoubleUpDownStyle}"
                                            Value="{Binding ScanDeduplicateToleranceMm}" />

                                    </Grid>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>

                    </TabItem>

                    <TabItem Header="相机调试">
                        <views:HkCameraControl />
                    </TabItem>

                </TabControl>

            </TabItem>

            <TabItem Header="一道探测参数">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="{StaticResource Brush.Status.Green}"
                        Text="0 代表本圈不探测，其他数字 N 代表本圈探测次数" />

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,0,0,10"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DetectionRingItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DetectionRingItem}">
                                    <Grid Height="30" Margin="45,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Text="{Binding Index, StringFormat=第{0}圈}" />
                                        <hc:NumericUpDown
                                            Grid.Column="1"
                                            Margin="0"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding DetectionCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,8,0,12"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Text="探测偏移量阈值：" />
                        <hc:NumericUpDown
                            Width="160"
                            Height="28"
                            Margin="0"
                            Style="{StaticResource NumericIntUpDownStyle}"
                            Value="{Binding DetectionOffsetThreshold, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="110"
                            Height="34"
                            Command="{Binding ResetDetectionCommand}"
                            Content="重置" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="二道探测参数">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="{StaticResource Brush.Status.Green}"
                        Text="0 代表本圈不探测，其他数字 N 代表本圈探测次数" />

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,0,0,10"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SecondPassDetectionItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SecondPassDetectionItem}">
                                    <Grid Height="30" Margin="45,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Text="{Binding Index, StringFormat=第{0}圈}" />
                                        <hc:NumericUpDown
                                            Grid.Column="1"
                                            Margin="0"
                                            Style="{StaticResource NumericIntUpDownStyle}"
                                            Value="{Binding DetectionCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,8,0,12"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Text="探测偏移量阈值：" />
                        <hc:NumericUpDown
                            Width="160"
                            Height="28"
                            Margin="0"
                            Style="{StaticResource NumericIntUpDownStyle}"
                            Value="{Binding SecondPassOffsetThreshold, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="110"
                            Height="34"
                            Command="{Binding ResetSecondPassDetectionCommand}"
                            Content="重置" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Border
            Grid.Column="1"
            Margin="10,0,0,0"
            Padding="12"
            Background="{StaticResource Brush.Background}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="6">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="全局操作" />

                <Button
                    Height="38"
                    Margin="0,0,0,8"
                    Background="{StaticResource Brush.Status.Green}"
                    Command="{Binding SaveConfigCommand}"
                    Content="保存"
                    FontWeight="Bold" />

                <Button
                    Height="38"
                    Margin="0,0,0,8"
                    Command="{Binding CancelChangesCommand}"
                    Content="取消" />

                <Button
                    Height="38"
                    Margin="0,0,0,12"
                    Command="{Binding ApplyAndCloseCommand}"
                    CommandParameter="{Binding ElementName=thisWin}"
                    Content="保存并关闭" />

                <Separator Margin="0,0,0,10" />

                <TextBlock
                    Margin="0,0,0,6"
                    FontWeight="SemiBold"
                    Text="已修改参数" />
                <TextBlock
                    Foreground="{StaticResource Brush.Foreground.Secondary}"
                    Text="{Binding ModifiedParametersInfo}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
