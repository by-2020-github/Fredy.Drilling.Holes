<Window x:Class="Fredy.Drilling.Holes.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
        xmlns:models="clr-namespace:Fredy.Drilling.Holes.Models"
        mc:Ignorable="d" x:Name="thisWin"
        Title="参数配置" Height="750" Width="1200" Background="#F0F0F0"
        d:DataContext="{d:DesignInstance Type=vm:ConfigViewModel, IsDesignTimeCreatable=True}">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0">
            <TabItem Header="运动参数设置">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,10,0">
                            <GroupBox Header="运动控制卡" Background="#DDEBF7" Margin="0,0,0,10" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="控制卡类型" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding MotionControllerTypes}"
                                              SelectedItem="{Binding MotionController.ControllerType}"
                                              Margin="5,0,15,0"/>
                                    <TextBlock Grid.Column="2" Text="连接字符串" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding MotionConnectionOptions}"
                                              Text="{Binding MotionController.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True"
                                              Margin="5,0,0,0"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="XY驱动参数" Background="#D6EAF8" Margin="0,0,0,10" Padding="10">
                                <WrapPanel VerticalAlignment="Center">
                                    <TextBlock Text="初速度" VerticalAlignment="Center" Margin="5,0"/>
                                    <TextBox Text="{Binding XyDrive.StartSpeed}" Width="80" Height="25"/>
                                    <TextBlock Text="驱动速度" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                    <TextBox Text="{Binding XyDrive.DriveSpeed}" Width="80"/>
                                    <TextBlock Text="加速度" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                    <TextBox Text="{Binding XyDrive.Acceleration}" Width="80"/>
                                    <TextBlock Text="延时" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                    <TextBox Text="{Binding XyDrive.Delay}" Width="60"/>
                                    <TextBlock Text="脉冲当量" VerticalAlignment="Center" Margin="15,10,5,0" HorizontalAlignment="Left"/>
                                    <TextBox Text="{Binding XyDrive.PulseEquivalent}" Width="80" Margin="0,10,0,0"/>
                                    <TextBlock Text="(每mm脉冲数)" VerticalAlignment="Center" Margin="5,10,0,0"/>
                                </WrapPanel>
                            </GroupBox>

                            <GroupBox Header="Z轴参数" Background="#008080" Foreground="White" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <WrapPanel Margin="0,0,0,10">
                                        <TextBlock Text="初速度" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBox Text="{Binding ZAxisBase.StartSpeed}" Width="80" Margin="5,0,15,0"/>
                                        <TextBlock Text="驱动速度" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBox Text="{Binding ZAxisBase.DriveSpeed}" Width="80" Margin="5,0,15,0"/>
                                        <TextBlock Text="加速度" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBox Text="{Binding ZAxisBase.Acceleration}" Width="80" Margin="5,0,15,0"/>
                                        <TextBlock Text="延时" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBox Text="{Binding ZAxisBase.Delay}" Width="60" Margin="5,0"/>
                                    </WrapPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <GroupBox Header="头道参数" Foreground="White" Grid.Column="0" Margin="2">
                                            <StackPanel Margin="5">
                                                <TextBlock Text="初速度"/>
                                                <TextBox Text="{Binding FirstPass.StartSpeed}" Margin="0,2,0,5"/>
                                                <TextBlock Text="驱动速度"/>
                                                <TextBox Text="{Binding FirstPass.DriveSpeed}" Margin="0,2,0,5"/>
                                                <TextBlock Text="加速度"/>
                                                <TextBox Text="{Binding FirstPass.Acceleration}" Margin="0,2,0,5"/>
                                            </StackPanel>
                                        </GroupBox>
                                        <GroupBox Header="二道参数" Foreground="White" Grid.Column="1" Margin="2">
                                            <StackPanel Margin="5">
                                                <TextBlock Text="初速度"/>
                                                <TextBox Text="{Binding SecondPass.StartSpeed}" Margin="0,2,0,5"/>
                                                <TextBlock Text="驱动速度"/>
                                                <TextBox Text="{Binding SecondPass.DriveSpeed}" Margin="0,2,0,5"/>
                                                <TextBlock Text="加速度"/>
                                                <TextBox Text="{Binding SecondPass.Acceleration}" Margin="0,2,0,5"/>
                                            </StackPanel>
                                        </GroupBox>
                                        <GroupBox Header="探测参数" Foreground="White" Grid.Column="2" Margin="2">
                                            <StackPanel Margin="5">
                                                <TextBlock Text="快速移动位置"/>
                                                <TextBox Text="{Binding FastMovePos}" Margin="0,2,0,5"/>
                                                <TextBlock Text="快速速度"/>
                                                <TextBox Text="{Binding FastMoveSpeed}" Margin="0,2,0,5"/>
                                                <TextBlock Text="慢速移动距离"/>
                                                <TextBox Text="{Binding SlowMoveDist}" Margin="0,2,0,5"/>
                                                <TextBlock Text="慢速速度"/>
                                                <TextBox Text="{Binding SlowMoveSpeed}" Margin="0,2,0,5"/>
                                            </StackPanel>
                                        </GroupBox>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="XY回零参数" Background="#D6EAF8" Padding="10">
                                <StackPanel>
                                    <WrapPanel Margin="0,0,0,10">
                                        <TextBlock Text="初速度" VerticalAlignment="Center" Margin="5,0"/>
                                        <TextBox Text="300" Width="80"/>
                                        <TextBlock Text="搜索速度" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                        <TextBox Text="{Binding HomeSearchSpeed}" Width="80"/>
                                        <TextBlock Text="反向慢速" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                        <TextBox Text="300" Width="80"/>
                                        <TextBlock Text="Z相速度" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                        <TextBox Text="200" Width="80"/>
                                    </WrapPanel>
                                    <GroupBox Header="回零模式" Background="#4A77A8" Foreground="White">
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <CheckBox Content="IO回零" IsChecked="{Binding IsIoHome}" Foreground="White" Margin="15,0"/>
                                            <CheckBox Content="锁存" IsChecked="{Binding IsLatch}" Foreground="White" Margin="15,0"/>
                                            <CheckBox Content="光栅尺回零" IsChecked="{Binding IsGratingHome}" Foreground="White" Margin="15,0"/>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <GroupBox Grid.Column="1" Header="端口配置" Background="#FFA07A" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <GroupBox Header="输入端口" BorderBrush="#888" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="X机械零位" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding XLimitPort.PortIndex}" Margin="5,0"/>
                                        <CheckBox Grid.Column="2" Content="低电平" IsChecked="{Binding XLimitPort.IsLowLevelActive}" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="1" Header="输出端口" BorderBrush="#888">
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="红灯" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding RedLightPort}" Margin="5,2"/>
                                    <TextBlock Grid.Row="1" Text="绿灯" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="0" Margin="5,2"/>
                                    <TextBlock Grid.Row="2" Text="黄灯" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="0" Margin="5,2"/>
                                    <TextBlock Grid.Row="3" Text="蜂鸣器" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="0" Margin="5,2"/>
                                </Grid>
                            </GroupBox>

                            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                                <CheckBox Content="调试模式" IsChecked="{Binding IsDebugMode}" Margin="0,5"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="相机参数">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="相机基础配置" Background="#DDEBF7" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="相机类型" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding CameraTypes}"
                                          SelectedItem="{Binding Camera.CameraType}"
                                          Margin="5,0,15,8"/>
                                <TextBlock Grid.Column="2" Text="连接字符串" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="3"
                                          ItemsSource="{Binding CameraConnectionOptions}"
                                          Text="{Binding Camera.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          Margin="5,0,0,8"/>

                                <TextBlock Grid.Row="1" Text="分辨率宽度" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Camera.ResolutionWidth}" Margin="5,0,15,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="分辨率高度" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Camera.ResolutionHeight}" Margin="5,0,0,0"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="像素尺寸" Background="#E2F0D9" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="像素尺寸 X (μm)" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Camera.PixelSizeX}" Margin="5,0,15,0"/>
                                <TextBlock Grid.Column="2" Text="像素尺寸 Y (μm)" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="3" Text="{Binding Camera.PixelSizeY}" Margin="5,0,0,0"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="视野尺寸" Background="#FCE4D6" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="视野宽度 (像素)" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Camera.FovWidth}" Margin="5,0,15,0"/>
                                <TextBlock Grid.Column="2" Text="视野高度 (像素)" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="3" Text="{Binding Camera.FovHeight}" Margin="5,0,0,0"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="一道探测参数">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="0 代表本圈不探测，其他数字 N 代表本圈探测次数"
                               Foreground="Green"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"
                               FontSize="14"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding DetectionRingItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DetectionRingItem}">
                                    <Grid Margin="45,2" Height="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Index, StringFormat=第{0}圈}" VerticalAlignment="Center" FontSize="14"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding DetectionCount, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center"
                                                 HorizontalContentAlignment="Left"
                                                 Padding="5,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,12">
                        <TextBlock Text="探测偏移量阈值：" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                        <TextBox Text="{Binding DetectionOffsetThreshold, UpdateSourceTrigger=PropertyChanged}" Width="160" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="重置"
                                Width="110"
                                Height="34"
                                Command="{Binding ResetDetectionCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="二道探测参数">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="0 代表本圈不探测，其他数字 N 代表本圈探测次数"
                               Foreground="Green"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"
                               FontSize="14"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding SecondPassDetectionItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SecondPassDetectionItem}">
                                    <Grid Margin="45,2" Height="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Index, StringFormat=第{0}圈}" VerticalAlignment="Center" FontSize="14"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding DetectionCount, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center"
                                                 HorizontalContentAlignment="Left"
                                                 Padding="5,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,12">
                        <TextBlock Text="探测偏移量阈值：" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                        <TextBox Text="{Binding SecondPassOffsetThreshold, UpdateSourceTrigger=PropertyChanged}" Width="160" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="重置"
                                Width="110"
                                Height="34"
                                Command="{Binding ResetSecondPassDetectionCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Column="1"
                Margin="10,0,0,0"
                Padding="12"
                Background="#FFFFFF"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="全局操作"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <Button Height="38"
                        Margin="0,0,0,8"
                        Background="#7FFF00"
                        FontWeight="Bold"
                        Content="保存"
                        Command="{Binding SaveConfigCommand}"/>

                <Button Height="38"
                        Margin="0,0,0,8"
                        Content="取消"
                        Command="{Binding CancelChangesCommand}"/>

                <Button Height="38"
                        Margin="0,0,0,12"
                        Content="保存并关闭"
                        Command="{Binding ApplyAndCloseCommand}"
                        CommandParameter="{Binding ElementName=thisWin}"/>

                <Separator Margin="0,0,0,10"/>

                <TextBlock Text="已修改参数"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{Binding ModifiedParametersInfo}"
                           TextWrapping="Wrap"
                           Foreground="#4F4F4F"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>