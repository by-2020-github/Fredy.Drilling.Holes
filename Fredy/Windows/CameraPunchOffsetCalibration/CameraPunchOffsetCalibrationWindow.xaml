<Window x:Class="Fredy.Drilling.Holes.Views.CameraPunchOffsetCalibrationWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
             xmlns:vm="clr-namespace:Fredy.Drilling.Holes.ViewModels"
             xmlns:models="clr-namespace:Fredy.Drilling.Holes.Models"
             xmlns:uc="clr-namespace:Fredy.Drilling.Holes.UserControls"
             mc:Ignorable="d" Background="{StaticResource Brush.Background.Subtle}"
             d:DesignHeight="1024" d:DesignWidth="1100"
             MaxHeight="1024" MaxWidth="1280" Height="Auto" 
              Title="相机/冲针偏移校准"
              d:DataContext="{d:DesignInstance Type=vm:CameraPunchOffsetCalibrationViewModel, IsDesignTimeCreatable=True}">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

                <!-- 点动控制 -->
                <Grid Grid.Row="0">
                    <Grid.Resources>
                        <Style TargetType="Button">
                            <Setter Property="FontSize" Value="18"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Margin" Value="3"/>
                            <Setter Property="Width" Value="62"/>
                            <Setter Property="Height" Value="62"/>
                        </Style>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="1" Grid.Column="0" Content="X-" Background="{StaticResource Brush.Status.Yellow}" Command="{Binding MoveAxisCommand}" CommandParameter="X-"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="X+" Background="{StaticResource Brush.Status.Yellow}" Command="{Binding MoveAxisCommand}" CommandParameter="X+"/>
                    <Button Grid.Row="0" Grid.Column="1" Content="Y+" Background="{StaticResource Brush.Status.Green}" Command="{Binding MoveAxisCommand}" CommandParameter="Y+"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="Y-" Background="{StaticResource Brush.Status.Green}" Command="{Binding MoveAxisCommand}" CommandParameter="Y-"/>
                    <Button Grid.Row="0" Grid.Column="4" Content="Z+" Background="{StaticResource Brush.Status.Blue}" Command="{Binding MoveAxisCommand}" CommandParameter="Z+"/>
                    <Button Grid.Row="2" Grid.Column="4" Content="Z-" Background="{StaticResource Brush.Status.Blue}" Command="{Binding MoveAxisCommand}" CommandParameter="Z-"/>
                </Grid>

                <!-- 点动步距 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="点动步距：" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ComboBox VerticalAlignment="Center" Width="180" Height="36" FontSize="18" ItemsSource="{Binding JogStepOptions}" SelectedItem="{Binding JogStep}"/>
                    <TextBlock Text="mm" FontSize="18" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- GPIO_IN -->
                <GroupBox Grid.Row="2" Header="GPIO_IN" Margin="0,6,0,0">
                    <ItemsControl ItemsSource="{Binding GpioIn}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="12"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GpioItem}">
                                <Border BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1" Margin="1" Height="22"
                                        Background="{Binding IsActive, Converter={StaticResource StatusColorConverter}}">
                                    <TextBlock Text="{Binding Id}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <!-- GPIO_OUT -->
                <GroupBox Grid.Row="3" Header="GPIO_OUT" Margin="0,4,0,0">
                    <ItemsControl ItemsSource="{Binding GpioOut}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GpioItem}">
                                <Button Width="28" Height="22" Margin="2" Padding="0"
                                        BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1"
                                        Background="{Binding IsActive, Converter={StaticResource StatusColorConverter}}"
                                        Command="{Binding DataContext.ToggleOutputCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}">
                                    <TextBlock Text="{Binding Id}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <!-- 机台坐标标题 -->
                <TextBlock Grid.Row="4" Text="机台坐标" FontSize="18" FontWeight="Bold" Margin="0,8,0,4"/>

                <!-- 机台坐标 -->
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="38"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" FontSize="22" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" FontSize="22" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Z:" FontSize="22" VerticalAlignment="Center" Margin="0,0,6,0"/>

                    <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource Brush.Status.Green}" Margin="0,3">
                        <TextBlock Text="{Binding MachineStatus.PosX, StringFormat=N3}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource Brush.Status.Green}" Margin="0,3">
                        <TextBlock Text="{Binding MachineStatus.PosY, StringFormat=N3}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource Brush.Status.Green}" Margin="0,3">
                        <TextBlock Text="{Binding MachineStatus.PosZ, StringFormat=N3}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    </Border>

                    <Button Grid.Row="0" Grid.Column="2" Content="X轴回零" Width="85" Margin="6,3,0,3" Command="{Binding HomeAxisCommand}" CommandParameter="X"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="Y轴回零" Width="85" Margin="6,3,0,3" Command="{Binding HomeAxisCommand}" CommandParameter="Y"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="Z轴回零" Width="85" Margin="6,3,0,3" Command="{Binding HomeAxisCommand}" CommandParameter="Z"/>
                </Grid>

                <!-- 坐标偏差校准（填满剩余高度） -->
                <GroupBox Grid.Row="6" Header="坐标偏差校准 (Offset)" Margin="0,8,0,0" Background="{StaticResource Brush.Background.Subtle}">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.4*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Content="1. 记录冲针" FontSize="14" Margin="3" Command="{Binding MarkPunchPositionCommand}"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="打孔" FontSize="14" Margin="3" Command="{Binding TestPunchCommand}" Background="{StaticResource Brush.Status.Red.Subtle}"/>
                        <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding PunchX, StringFormat=X: {0:F3}}" FontSize="12"/>
                            <TextBlock Text="{Binding PunchY, StringFormat=Y: {0:F3}}" FontSize="12"/>
                        </StackPanel>

                        <Button Grid.Row="1" Grid.Column="0" Content="2. 记录相机" FontSize="14" Margin="3" Command="{Binding MarkCameraPositionCommand}"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" Content="视觉辅助" VerticalAlignment="Center" HorizontalAlignment="Center" IsChecked="{Binding EnableVisionAssist}"/>
                        <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding CameraX, StringFormat=X: {0:F3}}" FontSize="12"/>
                            <TextBlock Text="{Binding CameraY, StringFormat=Y: {0:F3}}" FontSize="12"/>
                        </StackPanel>

                        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="3. 计算并应用 Offset"
                                FontSize="15" FontWeight="Bold" Margin="3"
                                Background="{StaticResource Brush.Status.Green}"
                                Command="{Binding CalculateAndSaveOffsetCommand}"/>
                        <StackPanel Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding OffsetX, StringFormat=dX: {0:F3}}" FontWeight="Bold" Foreground="{StaticResource Brush.Status.Red}" FontSize="14"/>
                            <TextBlock Text="{Binding OffsetY, StringFormat=dY: {0:F3}}" FontWeight="Bold" Foreground="{StaticResource Brush.Status.Red}" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
        </Grid>

        <Grid Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border x:Name="LiveVideo" BorderBrush="{StaticResource Brush.Border.Strong}" BorderThickness="1" Background="{StaticResource Brush.Background.Disabled}">
                <uc:CameraViewerControl ImageMat="{Binding CameraPreviewMat}" />
            </Border>
        </Grid>
    </Grid>
</Window>
