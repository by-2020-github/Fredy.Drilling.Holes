<Window x:Class="Fredy.Drilling.Holes.Windows.CustomPunchRange.CustomPunchRangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="自定义冲孔范围"
        Width="360"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Background.Subtle}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Text="设置当前 Recipe 需要冲孔的 index 范围"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" Text="起始 Index" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <hc:NumericUpDown Grid.Row="1"
                          Grid.Column="1"
                          Value="{Binding SelectedStartIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Minimum="1"
                          Maximum="{Binding MaxIndex}"
                          Style="{StaticResource NumericIntUpDownStyle}"
                          Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Text="终止 Index" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <hc:NumericUpDown Grid.Row="2"
                          Grid.Column="1"
                          Value="{Binding SelectedEndIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Minimum="1"
                          Maximum="{Binding MaxIndex}"
                          Style="{StaticResource NumericIntUpDownStyle}"
                          Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3"
                   Grid.ColumnSpan="2"
                   Text="{Binding RangeHint}"
                   Foreground="{StaticResource Brush.Foreground.Secondary}"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Width="90" Height="32" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="确定" Width="90" Height="32" Background="{StaticResource Brush.Status.Green}" Foreground="{StaticResource Brush.Foreground}" Click="ConfirmButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
